---
interface Props {
  topics: string[];
  states: string[];
  content_type: string[];
  tags: string[];
  youtube_url: string;
  date: string;
  duration: string;
}

const {
  topics,
  states,
  content_type,
  tags,
  youtube_url,
  date,
  duration,
} = Astro.props;

function formatTopic(topic: string): string {
  return topic.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<aside class="rounded-xl border border-border overflow-hidden">
  <!-- YouTube CTA -->
  <a
    href={youtube_url}
    target="_blank"
    rel="noopener"
    class="group flex items-center gap-3 bg-surface p-4 text-text hover:bg-surface-raised transition-colors border-b border-border"
  >
    <div class="w-9 h-9 rounded-lg bg-void flex items-center justify-center shrink-0 group-hover:bg-accent/10 transition-colors border border-border">
      <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.97 31.97 0 000 12a31.97 31.97 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.97 31.97 0 0024 12a31.97 31.97 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-sm font-[Archivo_Black] font-semibold text-text">Watch on YouTube</div>
      <div class="text-[11px] text-text-muted font-[JetBrains_Mono] mt-0.5">{duration} &middot; {formattedDate}</div>
    </div>
    <svg class="w-4 h-4 text-text-muted group-hover:text-accent group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
  </a>

  <!-- Metadata sections -->
  <div class="p-5 space-y-6 bg-surface">
    {topics.length > 0 && (
      <div>
        <h3 class="text-[11px] font-[JetBrains_Mono] font-bold text-text-muted uppercase tracking-[0.15em] mb-3 flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path d="M6 6h.008v.008H6V6Z"/></svg>
          Topics
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {topics.map(topic => (
            <a href={`/topics/${topic}`} class="tag-chip hover:border-accent hover:text-accent transition-colors capitalize">
              {formatTopic(topic)}
            </a>
          ))}
        </div>
      </div>
    )}

    {states.length > 0 && (
      <div>
        <h3 class="text-[11px] font-[JetBrains_Mono] font-bold text-text-muted uppercase tracking-[0.15em] mb-3 flex items-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          States
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {states.map(state => (
            <a href={`/states/${state.toLowerCase().replace(/\s+/g, '-')}`} class="tag-chip hover:border-accent hover:text-accent transition-all">
              {state}
            </a>
          ))}
        </div>
      </div>
    )}

    {content_type.length > 0 && (
      <div>
        <h3 class="text-[11px] font-[JetBrains_Mono] font-bold text-text-muted uppercase tracking-[0.15em] mb-3">Content Type</h3>
        <div class="flex flex-wrap gap-1.5">
          {content_type.map(type => (
            <span class="bg-accent/10 text-accent border border-accent/20 px-2.5 py-1 rounded text-[11px] font-[JetBrains_Mono] font-semibold capitalize">{type.replace(/-/g, ' ')}</span>
          ))}
        </div>
      </div>
    )}

    {tags.length > 0 && (
      <div>
        <h3 class="text-[11px] font-[JetBrains_Mono] font-bold text-text-muted uppercase tracking-[0.15em] mb-3">Tags</h3>
        <div class="flex flex-wrap gap-1.5">
          {tags.map(tag => (
            <span class="bg-void border border-border-subtle px-2 py-0.5 rounded text-[11px] font-[JetBrains_Mono] text-text-muted">{tag}</span>
          ))}
        </div>
      </div>
    )}
  </div>
</aside>
