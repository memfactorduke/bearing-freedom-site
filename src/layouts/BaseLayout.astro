---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Second Amendment commentary and analysis from Bearing Freedom', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Bearing Freedom" href="/rss.xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <title>{title} | Bearing Freedom</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={image} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Pagefind -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 backdrop-blur-xl bg-void/90 border-b border-border-subtle">
      <div class="max-w-7xl mx-auto px-5 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-3 group">
            <span class="text-accent font-[Archivo_Black] font-extrabold text-xl tracking-tight group-hover:opacity-80 transition-opacity">BF</span>
            <span class="hidden sm:block text-[13px] font-[Archivo_Black] font-medium tracking-wide text-text-secondary uppercase">Bearing Freedom</span>
          </a>

          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-text uppercase tracking-wide transition-colors">Articles</a>
            <a href="/videos" class="text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-text uppercase tracking-wide transition-colors">Videos</a>
            <a href="/topics" class="text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-text uppercase tracking-wide transition-colors">Topics</a>
            <a href="/search" class="text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-text uppercase tracking-wide transition-colors">Search</a>
            <a href="/contact" class="text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-text uppercase tracking-wide transition-colors">Contact</a>
            <a href="https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw" target="_blank" rel="noopener"
              class="text-[13px] font-[Archivo_Black] font-medium text-accent hover:text-accent-hover uppercase tracking-wide transition-colors flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.97 31.97 0 000 12a31.97 31.97 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.97 31.97 0 0024 12a31.97 31.97 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
              YT
            </a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden text-text-secondary hover:text-text p-1" aria-label="Toggle menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle">
        <div class="px-5 py-4 space-y-1 bg-void/95 backdrop-blur-xl">
          <a href="/" class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-accent uppercase tracking-wide">Articles</a>
          <a href="/videos" class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-accent uppercase tracking-wide">Videos</a>
          <a href="/topics" class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-accent uppercase tracking-wide">Topics</a>
          <a href="/search" class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-accent uppercase tracking-wide">Search</a>
          <a href="/contact" class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-text-secondary hover:text-accent uppercase tracking-wide">Contact</a>
          <div class="pt-3 border-t border-border-subtle">
            <a href="https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw" target="_blank" rel="noopener"
              class="block py-2.5 text-[13px] font-[Archivo_Black] font-medium text-accent uppercase tracking-wide">
              YouTube Channel
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border-subtle">
      <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16">
        <div class="grid md:grid-cols-3 gap-12 mb-12">
          <div>
            <span class="text-accent font-[Archivo_Black] font-extrabold text-2xl tracking-tight">BF</span>
            <p class="mt-4 text-sm leading-relaxed text-text-muted font-[Crimson_Pro] text-lg">
              Second Amendment commentary. No hedging, no apologies.
            </p>
          </div>

          <div>
            <h3 class="text-[11px] font-[Archivo_Black] font-bold text-text-muted uppercase tracking-[0.2em] mb-5">Navigate</h3>
            <ul class="space-y-3">
              <li><a href="/" class="text-sm text-text-secondary hover:text-accent transition-colors">Latest articles</a></li>
              <li><a href="/videos" class="text-sm text-text-secondary hover:text-accent transition-colors">Video library</a></li>
              <li><a href="/topics" class="text-sm text-text-secondary hover:text-accent transition-colors">Topics</a></li>
              <li><a href="/contact" class="text-sm text-text-secondary hover:text-accent transition-colors">Contact</a></li>
              <li><a href="/rss.xml" class="text-sm text-text-secondary hover:text-accent transition-colors inline-flex items-center gap-1.5">RSS <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg></a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-[11px] font-[Archivo_Black] font-bold text-text-muted uppercase tracking-[0.2em] mb-5">Connect</h3>
            <ul class="space-y-3">
              <li><a href="https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw" target="_blank" rel="noopener" class="text-sm text-text-secondary hover:text-accent transition-colors">YouTube</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-border-subtle pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-xs text-text-muted">Commentary and opinion. Not legal advice.</p>
          <p class="text-xs text-text-muted">&copy; {new Date().getFullYear()} Bearing Freedom</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-up');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-animate]').forEach(el => {
        el.style.opacity = '0';
        observer.observe(el);
      });
    </script>

  </body>
</html>
