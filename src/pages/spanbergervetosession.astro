---
// Standalone page — self-contained styles and scripts, no global.css
// Spanberger's 9 Bills — April 22, 2026 reconvened session recap
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Spanberger's Gun Bills: The House Said No | Bearing Freedom</title>
    <meta
      name="description"
      content="On April 22 the Virginia General Assembly met to act on Gov. Spanberger's recommended changes to six gun-bill packages. Her own caucus rejected the headline amendments. Here's every bill, every outcome, every next step."
    />
    <meta
      property="og:title"
      content="Spanberger's Gun Bills: The House Said No | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="Virginia's veto session tossed the governor's amendments on the assault weapons ban and the public-carry ban. Spanberger gets the original bills back on her desk. Sign as-passed or veto."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://bearingfreedom.com/spanbergervetosession"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q6WRV03TTZ"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q6WRV03TTZ', {
        send_page_view: true,
        allow_google_signals: true,
        allow_ad_personalization_signals: true,
        cookie_flags: 'SameSite=None;Secure',
        page_referrer: document.referrer,
        screen_resolution: window.screen.width + 'x' + window.screen.height,
      });
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --void: #07090f;
        --bg: #0b0f1a;
        --surface: #111627;
        --panel: #161d30;
        --panel-2: #1c2540;
        --border: #232c48;
        --border-dim: #1a2139;
        --text: #f2f5fb;
        --text-mid: #c5cdde;
        --text-dim: #8892a8;
        --text-faint: #596176;
        --red: #ef3b3b;
        --red-deep: #b91c1c;
        --red-glow: rgba(239, 59, 59, 0.2);
        --blue: #3b82f6;
        --blue-deep: #1e40af;
        --blue-glow: rgba(59, 130, 246, 0.18);
        --gold: #f5b129;
        --gold-deep: #a37a18;
        --green: #10b981;
        --purple: #a855f7;
        --grid: #1a2139;
        --display: 'Archivo Black', Impact, 'Helvetica Neue', sans-serif;
        --body: 'Inter', system-ui, -apple-system, sans-serif;
        --mono: 'JetBrains Mono', 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
        background: var(--void);
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a {
        color: var(--red);
        text-decoration: none;
      }
      a:hover {
        color: var(--text);
      }

      /* ═══ TOPBAR ═══ */
      .topbar {
        background: var(--void);
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 48px;
        border-bottom: 1px solid var(--border-dim);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .topbar-brand {
        font-family: var(--display);
        font-size: 18px;
        color: var(--text);
        letter-spacing: 0.5px;
      }
      .topbar-brand .tick {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--red);
        border-radius: 50%;
        margin-right: 8px;
        animation: pulse 1.8s ease-in-out infinite;
        vertical-align: middle;
        transform: translateY(-2px);
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          box-shadow: 0 0 0 0 var(--red-glow);
        }
        50% {
          opacity: 0.6;
          box-shadow: 0 0 0 6px rgba(239, 59, 59, 0);
        }
      }
      .topbar-links {
        display: flex;
        gap: 20px;
      }
      .topbar-links a {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-dim);
      }
      .topbar-links a:hover {
        color: var(--text);
      }

      /* ═══ TICKER ═══ */
      .ticker {
        background: var(--red-deep);
        overflow: hidden;
        white-space: nowrap;
        padding: 9px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.4);
      }
      .ticker-scroll {
        display: inline-block;
        animation: scroll 62s linear infinite;
      }
      .ticker-scroll span {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        color: #fff;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .ticker-sep {
        display: inline-block;
        width: 5px;
        height: 5px;
        background: rgba(255, 255, 255, 0.55);
        border-radius: 50%;
        margin: 0 22px;
        vertical-align: middle;
      }
      @keyframes scroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }

      /* ═══ HERO ═══ */
      .hero {
        position: relative;
        padding: 72px 24px 56px;
        border-bottom: 1px solid var(--border);
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(var(--grid) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: radial-gradient(
          ellipse at 50% 40%,
          #000 30%,
          transparent 70%
        );
        -webkit-mask-image: radial-gradient(
          ellipse at 50% 40%,
          #000 30%,
          transparent 70%
        );
        opacity: 0.55;
        pointer-events: none;
      }
      .hero-inner {
        position: relative;
        max-width: 1180px;
        margin: 0 auto;
        text-align: center;
      }
      .dateline {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--text-dim);
        margin-bottom: 28px;
      }
      .dateline .sep {
        color: var(--red);
        margin: 0 10px;
      }
      .hero-title {
        font-family: var(--display);
        font-size: clamp(54px, 10vw, 128px);
        line-height: 0.92;
        letter-spacing: -2px;
        color: var(--text);
        margin-bottom: 4px;
      }
      .hero-title .red {
        color: var(--red);
      }
      .hero-title .strike {
        position: relative;
        display: inline-block;
        color: var(--text-dim);
      }
      .hero-title .strike::after {
        content: '';
        position: absolute;
        left: -4%;
        right: -4%;
        top: 52%;
        height: 7px;
        background: var(--red);
        transform: rotate(-2.5deg);
      }
      .hero-deck {
        font-family: var(--body);
        font-size: clamp(18px, 2.2vw, 24px);
        color: var(--text-mid);
        max-width: 820px;
        margin: 28px auto 0;
        line-height: 1.45;
        font-weight: 400;
      }
      .hero-deck em {
        color: var(--gold);
        font-style: normal;
        font-weight: 600;
      }
      .hero-tags {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 32px;
      }
      .pill {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 6px 14px;
        border: 1px solid var(--border);
        color: var(--text-dim);
        border-radius: 999px;
        background: var(--surface);
      }
      .pill-red {
        border-color: var(--red);
        color: var(--red);
        background: var(--red-glow);
      }
      .pill-gold {
        border-color: var(--gold);
        color: var(--gold);
        background: rgba(245, 177, 41, 0.1);
      }
      .pill-green {
        border-color: var(--green);
        color: var(--green);
        background: rgba(16, 185, 129, 0.12);
      }

      /* ═══ SCOREBOARD ═══ */
      .scoreboard {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
      }
      .scoreboard-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border-dim);
      }
      .score-cell {
        background: var(--surface);
        padding: 36px 28px;
        text-align: center;
        position: relative;
      }
      .score-cell.rejected {
        background: linear-gradient(
          180deg,
          rgba(239, 59, 59, 0.08) 0%,
          var(--surface) 80%
        );
      }
      .score-cell.accepted {
        background: linear-gradient(
          180deg,
          rgba(16, 185, 129, 0.06) 0%,
          var(--surface) 80%
        );
      }
      .score-cell.pending {
        background: linear-gradient(
          180deg,
          rgba(245, 177, 41, 0.06) 0%,
          var(--surface) 80%
        );
      }
      .score-lbl {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--text-dim);
        margin-bottom: 14px;
      }
      .score-val {
        font-family: var(--display);
        font-size: 72px;
        line-height: 1;
        color: var(--text);
        font-variant-numeric: tabular-nums;
        margin-bottom: 8px;
      }
      .score-cell.rejected .score-val {
        color: var(--red);
      }
      .score-cell.accepted .score-val {
        color: var(--green);
      }
      .score-cell.pending .score-val {
        color: var(--gold);
      }
      .score-sub {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-mid);
        letter-spacing: 0.08em;
      }
      .score-note {
        font-family: var(--body);
        font-size: 13px;
        color: var(--text-dim);
        max-width: 220px;
        margin: 12px auto 0;
        line-height: 1.5;
      }
      @media (max-width: 760px) {
        .scoreboard-inner {
          grid-template-columns: 1fr;
        }
        .score-val {
          font-size: 60px;
        }
      }

      /* ═══ STATS STRIP ═══ */
      .stats {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        background: var(--void);
        border-bottom: 1px solid var(--border);
      }
      .stat {
        padding: 26px 16px;
        text-align: center;
        border-right: 1px solid var(--border-dim);
      }
      .stat:last-child {
        border-right: none;
      }
      .stat-val {
        font-family: var(--display);
        font-size: 30px;
        line-height: 1;
        color: var(--text);
        font-variant-numeric: tabular-nums;
      }
      .stat-val.red {
        color: var(--red);
      }
      .stat-val.gold {
        color: var(--gold);
      }
      .stat-val.green {
        color: var(--green);
      }
      .stat-val .sub {
        font-size: 15px;
        color: var(--text-dim);
        font-family: var(--mono);
        font-weight: 500;
        margin-left: 4px;
      }
      .stat-lbl {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--text-dim);
        margin-top: 10px;
        line-height: 1.45;
      }
      @media (max-width: 900px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
        .stat {
          border-bottom: 1px solid var(--border-dim);
        }
        .stat:nth-child(2n) {
          border-right: none;
        }
      }

      /* ═══ SECTION ═══ */
      .section {
        max-width: 1100px;
        margin: 0 auto;
        padding: 80px 24px;
        border-bottom: 1px solid var(--border-dim);
      }
      .section-wide {
        max-width: 1280px;
      }
      .section-label {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--red);
        margin-bottom: 14px;
      }
      .section-label .num {
        color: var(--text-faint);
        margin-right: 10px;
      }
      .section-title {
        font-family: var(--display);
        font-size: clamp(32px, 4.6vw, 56px);
        line-height: 1.02;
        letter-spacing: -1px;
        color: var(--text);
        margin-bottom: 16px;
      }
      .section-title .red {
        color: var(--red);
      }
      .section-title .gold {
        color: var(--gold);
      }
      .section-deck {
        font-size: 18px;
        color: var(--text-mid);
        max-width: 760px;
        margin-bottom: 48px;
        line-height: 1.55;
      }

      /* ═══ PROSE ═══ */
      .prose {
        font-size: 17px;
        line-height: 1.75;
        color: var(--text-mid);
        max-width: 760px;
      }
      .prose p {
        margin-bottom: 18px;
      }
      .prose strong {
        color: var(--text);
        font-weight: 700;
      }
      .prose em {
        color: var(--gold);
        font-style: normal;
        font-weight: 600;
      }

      /* ═══ PROCESS DIAGRAM ═══ */
      .process {
        margin-top: 32px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: 1px solid var(--border);
        background: var(--panel);
      }
      .process-step {
        padding: 22px 20px;
        border-right: 1px solid var(--border);
        position: relative;
      }
      .process-step:last-child {
        border-right: none;
      }
      .process-step::after {
        content: '▸';
        position: absolute;
        right: -9px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--red);
        background: var(--bg);
        width: 18px;
        height: 18px;
        display: grid;
        place-items: center;
        font-size: 12px;
        border: 1px solid var(--border);
        z-index: 2;
      }
      .process-step:last-child::after {
        display: none;
      }
      .process-num {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--red);
        letter-spacing: 0.2em;
        margin-bottom: 10px;
      }
      .process-head {
        font-family: var(--display);
        font-size: 15px;
        color: var(--text);
        margin-bottom: 8px;
        line-height: 1.1;
      }
      .process-body {
        font-size: 13px;
        color: var(--text-dim);
        line-height: 1.55;
      }
      @media (max-width: 820px) {
        .process {
          grid-template-columns: 1fr;
        }
        .process-step {
          border-right: none;
          border-bottom: 1px solid var(--border);
        }
        .process-step:last-child {
          border-bottom: none;
        }
        .process-step::after {
          display: none;
        }
      }

      /* ═══ BILL CARDS ═══ */
      .bill-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-top: 8px;
      }
      @media (max-width: 900px) {
        .bill-grid {
          grid-template-columns: 1fr;
        }
      }
      .bill {
        position: relative;
        background: var(--panel);
        border: 1px solid var(--border);
        overflow: hidden;
      }
      .bill-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 20px 24px 16px;
        border-bottom: 1px solid var(--border);
        gap: 18px;
      }
      .bill-meta {
        flex: 1;
        min-width: 0;
      }
      .bill-num {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--text-faint);
        letter-spacing: 0.24em;
        margin-bottom: 8px;
      }
      .bill-ids {
        font-family: var(--display);
        font-size: 24px;
        color: var(--text);
        letter-spacing: -0.2px;
        line-height: 1.05;
        margin-bottom: 6px;
      }
      .bill-topic {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--gold);
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }
      .bill-topic.topic-2a {
        color: var(--red);
      }
      .bill-topic.topic-cannabis {
        color: var(--green);
      }
      .bill-topic.topic-ice {
        color: var(--blue);
      }
      .bill-topic.topic-health {
        color: var(--purple);
      }
      .stamp {
        font-family: var(--display);
        font-size: 13px;
        letter-spacing: 0.14em;
        padding: 8px 14px;
        border: 2px solid;
        border-radius: 2px;
        text-transform: uppercase;
        transform: rotate(-2deg);
        white-space: nowrap;
        line-height: 1;
        align-self: flex-start;
        flex-shrink: 0;
      }
      .stamp.rejected {
        color: var(--red);
        border-color: var(--red);
        background: rgba(239, 59, 59, 0.08);
      }
      .stamp.accepted {
        color: var(--green);
        border-color: var(--green);
        background: rgba(16, 185, 129, 0.08);
      }
      .stamp.pending {
        color: var(--gold);
        border-color: var(--gold);
        background: rgba(245, 177, 41, 0.08);
      }
      .stamp.showdown {
        color: var(--red);
        border-color: var(--red);
        background: rgba(239, 59, 59, 0.08);
      }
      .bill-body {
        padding: 4px 24px 22px;
      }
      .bill-row {
        padding: 16px 0;
        border-bottom: 1px solid var(--border-dim);
      }
      .bill-row:last-child {
        border-bottom: none;
      }
      .bill-row-lbl {
        font-family: var(--mono);
        font-size: 9px;
        color: var(--text-faint);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .bill-row-lbl.accent {
        color: var(--red);
      }
      .bill-row-lbl.accent-g {
        color: var(--green);
      }
      .bill-row-lbl.accent-y {
        color: var(--gold);
      }
      .bill-row-body {
        font-size: 15px;
        color: var(--text-mid);
        line-height: 1.6;
      }
      .bill-row-body strong {
        color: var(--text);
        font-weight: 700;
      }
      .bill-row-body em {
        color: var(--gold);
        font-style: normal;
        font-weight: 600;
      }
      .bill-row-body .red {
        color: var(--red);
        font-weight: 600;
      }

      /* ═══ CALLOUT ═══ */
      .callout {
        position: relative;
        background: var(--void);
        border: 1px solid var(--red);
        border-left-width: 6px;
        padding: 40px 44px 36px;
        margin: 16px 0 0;
        overflow: hidden;
      }
      .callout::before {
        content: 'EDITORIAL';
        position: absolute;
        top: -10px;
        left: 24px;
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.25em;
        padding: 3px 10px;
        background: var(--bg);
        color: var(--red);
        border: 1px solid var(--red);
      }
      .callout-quote {
        font-family: var(--display);
        font-size: clamp(28px, 4vw, 44px);
        line-height: 1.08;
        color: var(--text);
        letter-spacing: -0.5px;
        margin-bottom: 22px;
      }
      .callout-quote .red {
        color: var(--red);
      }
      .callout-quote .gold {
        color: var(--gold);
      }
      .callout-body {
        font-size: 17px;
        color: var(--text-mid);
        line-height: 1.7;
        max-width: 760px;
      }
      .callout-body strong {
        color: var(--text);
        font-weight: 700;
      }
      .callout-body p {
        margin-bottom: 14px;
      }
      .callout-body p:last-child {
        margin-bottom: 0;
      }

      /* ═══ DECISION MATRIX ═══ */
      .matrix {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }
      @media (max-width: 820px) {
        .matrix {
          grid-template-columns: 1fr;
        }
      }
      .matrix-cell {
        background: var(--panel);
        border: 1px solid var(--border);
        padding: 22px 22px 20px;
        position: relative;
      }
      .matrix-cell.red {
        border-color: var(--red);
      }
      .matrix-cell.gold {
        border-color: var(--gold);
      }
      .matrix-cell.green {
        border-color: var(--green);
      }
      .matrix-head {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .matrix-cell.red .matrix-head {
        color: var(--red);
      }
      .matrix-cell.gold .matrix-head {
        color: var(--gold);
      }
      .matrix-cell.green .matrix-head {
        color: var(--green);
      }
      .matrix-title {
        font-family: var(--display);
        font-size: 22px;
        color: var(--text);
        margin-bottom: 10px;
        line-height: 1.1;
      }
      .matrix-body {
        font-size: 14px;
