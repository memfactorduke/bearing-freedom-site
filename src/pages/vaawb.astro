---
// Standalone page — self-contained styles and scripts, no global.css
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Virginia Assault Weapons Ban (SB 749) | Bearing Freedom</title>
    <meta
      name="description"
      content="Governor Spanberger signed SB 749 into law on May 14, 2026 after the General Assembly rejected her amendments to broaden the ban. Full breakdown of the six-category feature test, magazine caps, penalties, exemptions, and the three lawsuits filed within 24 hours."
    />
    <meta
      property="og:title"
      content="Virginia Assault Weapons Ban (SB 749) | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="Spanberger signed it. Six categories. The amendment she pushed got killed. Three lawsuits in 24 hours. Effective July 1, 2026."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bearingfreedom.com/vaawb" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q6WRV03TTZ"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q6WRV03TTZ', {
        send_page_view: true,
        allow_google_signals: true,
        allow_ad_personalization_signals: true,
        cookie_flags: 'SameSite=None;Secure',
        page_referrer: document.referrer,
        screen_resolution: window.screen.width + 'x' + window.screen.height,
      });
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --paper: #f4f0e8;
        --paper-dark: #e8e2d6;
        --ink: #1a1a1a;
        --ink-light: #3a3a3a;
        --ink-muted: #6b6560;
        --ink-faint: #9a9590;
        --red: #b91c1c;
        --red-bg: #fef2f2;
        --red-border: #f5c6c6;
        --green: #166534;
        --green-bg: #f0fdf4;
        --green-border: #bbf7d0;
        --amber: #92400e;
        --amber-bg: #fffbeb;
        --amber-border: #fde68a;
        --navy: #1e3a5f;
        --navy-bg: #eef2f7;
        --black: #111;
        --white: #fff;
        --rule: #1a1a1a;
        --rule-light: #ccc5b8;
        --display: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --body: 'Lora', Georgia, serif;
        --mono: 'DM Mono', 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background: var(--paper);
        color: var(--ink);
        font-family: var(--body);
        font-size: 18px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      a {
        color: var(--red);
      }
      a:hover {
        color: var(--ink);
      }

      /* ═══ TOPBAR ═══ */
      .topbar {
        background: var(--black);
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 44px;
      }
      .topbar-brand {
        font-family: var(--display);
        font-size: 20px;
        font-weight: 900;
        color: var(--white);
        text-decoration: none;
        letter-spacing: 0.5px;
      }
      .topbar-links {
        display: flex;
        gap: 20px;
      }
      .topbar-links a {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #999;
        text-decoration: none;
      }
      .topbar-links a:hover {
        color: var(--white);
      }

      /* ═══ TICKER ═══ */
      .ticker {
        background: var(--red);
        overflow: hidden;
        white-space: nowrap;
        padding: 8px 0;
      }
      .ticker-scroll {
        display: inline-block;
        animation: scroll 50s linear infinite;
      }
      .ticker-scroll span {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        color: var(--white);
        letter-spacing: 0.04em;
      }
      .ticker-sep {
        display: inline-block;
        width: 6px;
        height: 6px;
        background: rgba(255, 255, 255, 0.4);
        border-radius: 50%;
        margin: 0 24px;
        vertical-align: middle;
      }
      @keyframes scroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }

      /* ═══ MASTHEAD ═══ */
      .masthead {
        text-align: center;
        padding: 56px 24px 48px;
        border-bottom: 6px double var(--rule);
      }
      .masthead-dateline {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--ink-muted);
        margin-bottom: 20px;
      }
      .masthead h1 {
        font-family: var(--display);
        font-size: clamp(48px, 9vw, 96px);
        font-weight: 900;
        line-height: 0.95;
        letter-spacing: -1px;
        color: var(--ink);
        margin-bottom: 4px;
      }
      .masthead h1 .red {
        color: var(--red);
      }
      .masthead-deck {
        font-family: var(--display);
        font-size: clamp(18px, 2.5vw, 24px);
        font-weight: 400;
        font-style: italic;
        color: var(--ink-light);
        max-width: 700px;
        margin: 20px auto 0;
        line-height: 1.4;
      }
      .masthead-tags {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 28px;
      }
      .tag {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 5px 14px;
        border: 1.5px solid var(--rule-light);
        color: var(--ink-muted);
      }
      .tag-red {
        border-color: var(--red);
        color: var(--red);
        background: var(--red-bg);
      }
      .tag-amber {
        border-color: var(--amber);
        color: var(--amber);
        background: var(--amber-bg);
      }
      .tag-navy {
        border-color: var(--navy);
        color: var(--navy);
        background: var(--navy-bg);
      }

      /* ═══ STATS STRIP ═══ */
      .stats {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        border-bottom: 3px solid var(--rule);
      }
      .stat-box {
        padding: 24px 12px;
        text-align: center;
        border-right: 1px solid var(--rule-light);
      }
      .stat-box:last-child {
        border-right: none;
      }
      .stat-val {
        font-family: var(--display);
        font-size: 30px;
        font-weight: 900;
        color: var(--ink);
        line-height: 1;
      }
      .stat-val.red {
        color: var(--red);
      }
      .stat-val.amber {
        color: var(--amber);
      }
      .stat-val.navy {
        color: var(--navy);
      }
      .stat-lbl {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ink-muted);
        margin-top: 8px;
      }

      /* ═══ CONTENT ═══ */
      .content {
        max-width: 780px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .section {
        padding: 64px 0;
        border-bottom: 1px solid var(--rule-light);
      }

      .section-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--ink-faint);
        margin-bottom: 8px;
      }

      .section-title {
        font-family: var(--display);
        font-size: 40px;
        font-weight: 900;
        color: var(--ink);
        line-height: 1.1;
        margin-bottom: 28px;
        letter-spacing: -0.5px;
      }
      .section-title .red {
        color: var(--red);
      }

      .prose {
        font-family: var(--body);
        font-size: 19px;
        line-height: 1.8;
        color: var(--ink-light);
      }
      .prose strong {
        color: var(--ink);
        font-weight: 600;
      }
      .prose em {
        font-style: italic;
      }
      .prose p {
        margin-bottom: 20px;
      }
      .prose p:last-child {
        margin-bottom: 0;
      }

      /* ═══ THE STRIKETHROUGH AMENDMENT BEAT ═══ */
      .strike-card {
        background: var(--white);
        border: 2px solid var(--ink);
        padding: 40px 32px;
        margin: 32px 0;
        text-align: center;
        position: relative;
      }
      .strike-card-label {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--red);
        margin-bottom: 20px;
      }
      .strike-card-quote {
        font-family: var(--display);
        font-size: clamp(22px, 3.6vw, 32px);
        line-height: 1.4;
        color: var(--ink);
        font-weight: 700;
      }
      .strike-card-quote .struck {
        text-decoration: line-through;
        text-decoration-color: var(--red);
        text-decoration-thickness: 4px;
        color: var(--ink-faint);
      }
      .strike-card-quote .kept {
        color: var(--red);
        background: var(--red-bg);
        padding: 0 6px;
      }
      .strike-card-note {
        font-family: var(--body);
        font-size: 15px;
        font-style: italic;
        color: var(--ink-muted);
        margin-top: 20px;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      /* ═══ CALLOUTS ═══ */
      .callout {
        border: 2px solid var(--rule);
        padding: 24px 28px;
        margin: 28px 0;
        background: var(--white);
      }
      .callout-danger {
        border-color: var(--red);
        border-left-width: 5px;
        background: var(--red-bg);
      }
      .callout-warning {
        border-color: var(--amber);
        border-left-width: 5px;
        background: var(--amber-bg);
      }
      .callout-safe {
        border-color: var(--green);
        border-left-width: 5px;
        background: var(--green-bg);
      }
      .callout-navy {
        border-color: var(--navy);
        border-left-width: 5px;
        background: var(--navy-bg);
      }
      .callout-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ink-muted);
        margin-bottom: 8px;
      }
      .callout-danger .callout-label {
        color: var(--red);
      }
      .callout-warning .callout-label {
        color: var(--amber);
      }
      .callout-safe .callout-label {
        color: var(--green);
      }
      .callout-navy .callout-label {
        color: var(--navy);
      }
      .callout p {
        font-family: var(--body);
        font-size: 16px;
        line-height: 1.7;
        color: var(--ink-light);
        margin: 0;
      }
      .callout p + p {
        margin-top: 12px;
      }
      .callout p strong {
        color: var(--ink);
      }

      /* ═══ CATEGORY CARDS (one per beat, vertical) ═══ */
      .cat {
        background: var(--white);
        border: 2px solid var(--ink);
        padding: 32px 28px;
        margin-bottom: 20px;
      }
      .cat-num-row {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }
      .cat-num {
        font-family: var(--display);
        font-size: 56px;
        font-weight: 900;
        color: var(--red);
        line-height: 1;
        letter-spacing: -2px;
      }
      .cat-headline {
        font-family: var(--display);
        font-size: 26px;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.2;
        flex: 1;
        min-width: 240px;
      }
      .cat-body {
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.65;
        color: var(--ink-light);
      }
      .cat-body strong {
        color: var(--ink);
        font-weight: 600;
      }
      .cat-features {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid var(--rule-light);
      }
      .cat-features-label {
        font-family: var(--mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-faint);
        margin-bottom: 8px;
      }
      .cat-features-list {
        font-family: var(--body);
        font-size: 16px;
        color: var(--ink);
        line-height: 1.6;
      }

      /* ═══ TABLES ═══ */
      .tbl {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-family: var(--body);
        font-size: 16px;
        border: 2px solid var(--ink);
      }
      .tbl thead th {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 12px 16px;
        text-align: left;
        background: var(--ink);
        color: var(--white);
        border-bottom: 2px solid var(--ink);
      }
      .tbl tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--rule-light);
        color: var(--ink-light);
        vertical-align: top;
      }
      .tbl tbody tr:nth-child(even) {
        background: rgba(0, 0, 0, 0.02);
      }
      .tbl tbody tr:hover {
        background: rgba(0, 0, 0, 0.04);
      }
      .tbl td strong {
        color: var(--ink);
        font-weight: 600;
      }

      .badge {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 3px 10px;
        display: inline-block;
        white-space: nowrap;
      }
      .badge-ban {
        background: var(--red);
        color: var(--white);
      }
      .badge-ok {
        background: var(--green);
        color: var(--white);
      }
      .badge-tbd {
        background: var(--amber);
        color: var(--white);
      }
      .badge-navy {
        background: var(--navy);
        color: var(--white);
      }

      /* ═══ LIST ═══ */
      .check-list {
        margin: 20px 0;
      }
      .check-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--rule-light);
        font-size: 17px;
        color: var(--ink-light);
        line-height: 1.6;
      }
      .check-dot {
        flex-shrink: 0;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-top: 9px;
      }
      .check-item strong {
        color: var(--ink);
        font-weight: 600;
      }

      /* ═══ TIMELINE ═══ */
      .timeline {
        position: relative;
        margin: 28px 0;
        padding-left: 28px;
        border-left: 3px solid var(--ink);
      }
      .tl-item {
        position: relative;
        padding: 18px 0 18px 24px;
      }
      .tl-item::before {
        content: '';
        position: absolute;
        left: -20px;
        top: 24px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--paper);
        border: 3px solid var(--ink-muted);
      }
      .tl-item.major::before {
        background: var(--red);
        border-color: var(--red);
      }
      .tl-date {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        color: var(--ink-muted);
        letter-spacing: 0.04em;
      }
      .tl-desc {
        font-family: var(--body);
        font-size: 17px;
        color: var(--ink-light);
        margin-top: 4px;
        line-height: 1.5;
      }
      .tl-item.major .tl-desc {
        color: var(--ink);
        font-weight: 600;
      }

      /* ═══ PULLQUOTE ═══ */
      .pullquote {
        font-family: var(--display);
        font-size: clamp(24px, 3.5vw, 32px);
        font-weight: 700;
        font-style: italic;
        color: var(--ink);
        text-align: center;
        padding: 56px 32px;
        margin: 0;
        border-top: 3px solid var(--rule);
        border-bottom: 3px solid var(--rule);
        line-height: 1.35;
      }
      .pullquote .red {
        color: var(--red);
      }
      .pullquote-attribution {
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ink-muted);
        font-style: normal;
        font-weight: 500;
        margin-top: 20px;
        display: block;
      }

      /* ═══ INVERTED BLOCK ═══ */
      .inverted {
        background: var(--ink);
        color: var(--white);
        padding: 48px 24px;
        margin: 0 -24px;
        text-align: center;
      }
      .inverted-wide {
        margin: 0;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        padding: 72px 24px;
      }
      .inverted h2 {
        font-family: var(--display);
        font-size: clamp(24px, 3vw, 30px);
        font-weight: 700;
        color: var(--white);
        margin-bottom: 20px;
        letter-spacing: 0.3px;
        max-width: 720px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.3;
      }
      .inverted p {
        font-family: var(--body);
        font-size: 17px;
        color: #bbb;
        max-width: 600px;
        margin: 0 auto 24px;
        line-height: 1.7;
      }
      .sub-btn {
        display: inline-block;
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 500;
        padding: 14px 36px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: var(--red);
        color: var(--white);
        text-decoration: none;
        transition: background 0.2s;
      }
      .sub-btn:hover {
        background: #991b1b;
        color: var(--white);
      }

      /* ═══ BIG STAT (full-bleed beats) ═══ */
      .big-stat {
        text-align: center;
        padding: 56px 24px;
        background: var(--white);
        border: 2px solid var(--ink);
        margin: 32px 0;
      }
      .big-stat-num {
        font-family: var(--display);
        font-size: clamp(80px, 16vw, 160px);
        font-weight: 900;
        line-height: 1;
        color: var(--red);
        letter-spacing: -4px;
      }
      .big-stat-lbl {
        font-family: var(--mono);
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--ink);
        margin-top: 16px;
        font-weight: 500;
      }
      .big-stat-note {
        font-family: var(--body);
        font-size: 17px;
        font-style: italic;
        color: var(--ink-muted);
        margin-top: 12px;
      }

      /* ═══ FOOTER ═══ */
      .foot {
        border-top: 3px solid var(--rule);
        padding: 24px;
        text-align: center;
      }
      .foot p {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--ink-muted);
        letter-spacing: 0.06em;
        margin: 0;
      }

      /* ═══ REVEAL ═══ */
      [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      [data-reveal].vis {
        opacity: 1;
        transform: translateY(0);
      }

      /* ═══ RESPONSIVE ═══ */
      @media (max-width: 768px) {
        .stats {
          grid-template-columns: repeat(3, 1fr);
        }
        .topbar-links {
          display: none;
        }
        .masthead {
          padding: 40px 20px 36px;
        }
        .section {
          padding: 48px 0;
        }
        .section-title {
          font-size: 32px;
        }
        .pullquote {
          padding: 40px 20px;
        }
        .inverted {
          margin: 0 -20px;
        }
        .cat {
          padding: 24px 22px;
        }
        .cat-num {
          font-size: 44px;
        }
        .cat-headline {
          font-size: 22px;
        }
        .strike-card {
          padding: 28px 20px;
        }
      }
      @media (max-width: 480px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
        .masthead h1 {
          font-size: 42px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Topbar -->
    <div class="topbar">
      <a href="/" class="topbar-brand">Bearing Freedom</a>
      <div class="topbar-links">
        <a href="/">Articles</a>
        <a href="/extras">Extras</a>
        <a href="/legislation">VA Tracker</a>
        <a
          href="https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw"
          target="_blank"
          rel="noopener">YouTube</a
        >
      </div>
    </div>

    <!-- Ticker -->
    <div class="ticker">
      <div class="ticker-scroll">
        <span>SB 749 signed into law by Gov. Spanberger</span><span
