    id: 'fulton',
    name: 'Junius P. Fulton III',
    role: 'Associate Justice',
    appointer: 'Democratic GA, 2025',
    termEnds: 'Dec 31, 2037',
    retirement: '2031',
    leanIndex: 6,
    call: 'Uphold',
    confidence: 'Medium-High',
    color: '#3f4c66',
    bench: 'Liberal',
    chair: 7,
    summary:
