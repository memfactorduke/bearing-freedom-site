                <tr>
                  <td class="justice">Mann</td>
                  <td>Jul 31, 2034</td>
                  <td>mid-late 2030s</td>
                  <td class="text">Far enough out</td>
                  <td><span class="level none">None</span></td>
                </tr>
                <tr>
                  <td class="justice">Fulton</td>
                  <td>Dec 31, 2037</td>
                  <td><b>2031</b></td>
