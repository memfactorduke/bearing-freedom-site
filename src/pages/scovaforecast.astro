    <script is:inline>
      // Reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -60px 0px' },
      );
      document
        .querySelectorAll('[data-reveal]')
        .forEach((el) => io.observe(el));

      // Animate scenario probability bar widths once visible
      const sb = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const fills = entry.target.querySelectorAll('.scenario-bar-fill');
              fills.forEach((f) => {
                const pct = f.getAttribute('data-pct');
                requestAnimationFrame(() => {
                  f.style.width = pct + '%';
                });
              });
              sb.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 },
      );
      const scs = document.querySelector('.scenarios');
      if (scs) sb.observe(scs);
    </script>
