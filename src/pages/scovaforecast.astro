// Standalone page — self-contained styles and scripts, no global.css.
// Scott v. McDougle (consolidated with the RNC's Tazewell-2 petition).
// Forecast for the Supreme Court of Virginia's pending merits ruling on
// the April 21, 2026 mid-decade redistricting constitutional amendment.
// Drafted May 7, 2026 — ruling pending.

const justices = [
  {
    id: 'powell',
    name: 'Cleo E. Powell',
    role: 'Chief Justice',
    appointer: 'Republican GA, 2011 (Dem-registered consensus pick)',
    termEnds: 'Jul 31, 2035',
    retirement: 'Jan 12, 2030',
    leanIndex: 6, // 1 = strong strike, 7 = strong uphold
    call: 'Uphold',
    confidence: 'High',
    color: '#3f4c66',
    bench: 'CJ',
    chair: 4, // center seat on the bench
    summary:
      'Center-institutionalist. Concurred in result but rejected the textualist methodology in Vlaming. Her CJ tenure caps at four years under mandatory retirement. Built to hold the line on institutional deference.',
    keyPoints: [
      'Authored the Vlaming concurrence rejecting the majority\'s "overt acts" limiting principle — proposed strict-scrutiny instead.',
      'First African-American woman CJ in Virginia history. Strong institutional reasons not to define her tenure with a 4-3 nullification.',
      'The 1912 deference line is in her judicial-temperament wheelhouse.',
    ],
    flip: 'Only realistic flip: she reads Argument 2 (special-session scope) as a pure separation-of-powers question, not a textualist one. No public signal so far.',
  },
  {
    id: 'kelsey',
    name: 'D. Arthur Kelsey',
    role: 'Associate Justice',
    appointer: 'Republican GA, 2015 (unanimous)',
    termEnds: 'Jan 31, 2027',
    retirement: '~Oct 2034',
    leanIndex: 1,
