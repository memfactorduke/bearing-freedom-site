                <tr>
                  <td class="justice">Kelsey</td>
                  <td>Jan 31, 2027</td>
                  <td>2034</td>
                  <td class="text"
                    >Current Dem-majority GA · 2026 short session</td
                  >
                  <td><span class="level max">Maximum</span></td>
                </tr>
                <tr>
                  <td class="justice">McCullough</td>
