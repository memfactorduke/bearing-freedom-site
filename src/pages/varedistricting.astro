    <!-- COUNTDOWN SCRIPT + HEX TOOLTIPS -->
    <script is:inline>
      // Countdown to April 21, 2026 06:00 ET (polls open)
      (function () {
        const target = new Date('2026-04-21T06:00:00-04:00').getTime();
        const d = document.getElementById('cd-d');
        const h = document.getElementById('cd-h');
        const m = document.getElementById('cd-m');
        const s = document.getElementById('cd-s');
        function pad(n) {
          return String(Math.max(0, n)).padStart(2, '0');
        }
        function tick() {
          const now = Date.now();
          let delta = Math.max(0, target - now);
          const days = Math.floor(delta / 86400000);
          delta -= days * 86400000;
          const hrs = Math.floor(delta / 3600000);
          delta -= hrs * 3600000;
          const mins = Math.floor(delta / 60000);
          delta -= mins * 60000;
          const secs = Math.floor(delta / 1000);
          if (d) d.textContent = pad(days);
          if (h) h.textContent = pad(hrs);
          if (m) m.textContent = pad(mins);
          if (s) s.textContent = pad(secs);
        }
        tick();
        setInterval(tick, 1000);
      })();

      // Simple hex tooltip (title attribute fallback is fine; we add a floating label)
      (function () {
        const hexes = document.querySelectorAll('.hex[data-info]');
        let tip = document.createElement('div');
        tip.style.cssText =
          'position:fixed;pointer-events:none;z-index:100;background:#07090f;color:#f2f5fb;border:1px solid #ef3b3b;padding:8px 12px;font-family:JetBrains Mono,monospace;font-size:12px;max-width:260px;line-height:1.5;opacity:0;transition:opacity 0.12s;box-shadow:0 8px 24px rgba(0,0,0,0.5);';
        document.body.appendChild(tip);
        hexes.forEach(function (h) {
          h.addEventListener('mouseenter', function (e) {
            tip.textContent = h.getAttribute('data-info');
            tip.style.opacity = '1';
          });
          h.addEventListener('mousemove', function (e) {
            tip.style.left = e.clientX + 14 + 'px';
            tip.style.top = e.clientY + 14 + 'px';
          });
          h.addEventListener('mouseleave', function () {
            tip.style.opacity = '0';
          });
        });
      })();
    </script>
