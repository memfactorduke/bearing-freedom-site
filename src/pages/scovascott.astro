---
// Standalone page — self-contained styles and scripts, no global.css.
// Scott v. McDougle (and consolidated petitions) — the Virginia Supreme Court
// is weighing whether to nullify the April 21, 2026 redistricting amendment.
// Justice-by-justice vote analysis. Drafted May 7, 2026.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      SCOVA Watch: Scott v. McDougle — The Line is 4-3 | Bearing Freedom
    </title>
    <meta
      name="description"
      content="Justice-by-justice analysis of Scott v. McDougle, the challenge to Virginia's April 21, 2026 redistricting amendment. The Vlaming bloc, the textualist hook, the reappointment pressure map, and the six scenarios ranked by probability."
    />
    <meta
      property="og:title"
      content="SCOVA Watch: Scott v. McDougle | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="Seven justices. One referendum. The line is 4-3 — but it's a coin flip. Inside the Vlaming bloc, the reappointment calendar, and the case that decides whether 1.27 million Virginia voters get their map."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bearingfreedom.com/scovascott" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q6WRV03TTZ"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q6WRV03TTZ', {
        send_page_view: true,
        allow_google_signals: true,
        allow_ad_personalization_signals: true,
        cookie_flags: 'SameSite=None;Secure',
      });
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --void: #06080d;
        --bg: #0a0d16;
        --surface: #11151f;
        --panel: #161c2a;
        --panel-2: #1b2235;
        --border: #2a3145;
        --border-dim: #1d2336;
        --text: #f4f1e8;
        --text-mid: #c9c5b6;
        --text-dim: #8a8775;
        --text-faint: #5b5a4e;
        --gold: #d4a82a;
        --gold-deep: #8a6a18;
        --gold-glow: rgba(212, 168, 42, 0.18);

        /* Editorial framing: STRIKE = our side wins (gold). UPHOLD = the
           gerrymander stands (red threat). TOSSUP = the pivot (copper). */
        --strike: #d4a82a;
        --strike-deep: #8a6a18;
        --strike-glow: rgba(212, 168, 42, 0.30);

        --uphold: #c8333d;
        --uphold-deep: #7d1a22;
        --uphold-glow: rgba(200, 51, 61, 0.22);

        --tossup: #c47d3a;
        --tossup-deep: #7a4818;
        --tossup-glow: rgba(196, 125, 58, 0.22);

        --parchment: #ede4cf;
        --parchment-deep: #c9bd9d;

        --display: 'Archivo Black', Impact, sans-serif;
        --serif: 'Fraunces', Georgia, serif;
        --body: 'Inter', system-ui, sans-serif;
        --mono: 'JetBrains Mono', 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
        background: var(--void);
      }

      body {
        font-family: var(--body);
        background: var(--void);
        color: var(--text);
        line-height: 1.6;
        font-feature-settings: 'ss01', 'ss02', 'cv11';
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      ::selection {
        background: var(--gold);
        color: var(--void);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* ============================================================
         CAPTION RIBBON — sticky case caption at top
         ============================================================ */
      .caption-ribbon {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--void);
        border-bottom: 1px solid var(--border-dim);
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-dim);
      }
      .caption-ribbon-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 10px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }
      .caption-ribbon a {
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.15s;
      }
      .caption-ribbon a:hover {
        color: var(--gold);
      }
      .caption-cite {
        color: var(--gold);
      }
      .caption-dot {
        display: inline-block;
        width: 4px;
        height: 4px;
        background: var(--gold);
        border-radius: 50%;
        margin: 0 10px;
        vertical-align: middle;
      }
      .caption-pulse {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--strike);
      }
      .caption-pulse-dot {
        width: 7px;
        height: 7px;
        background: var(--strike);
        border-radius: 50%;
        animation: pulse 1.6s ease-in-out infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          box-shadow: 0 0 0 0 rgba(200, 51, 61, 0.6);
        }
        50% {
          opacity: 0.7;
          box-shadow: 0 0 0 8px rgba(200, 51, 61, 0);
        }
      }

      /* ============================================================
         WRAPPER + SECTION
         ============================================================ */
      .wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
      }
      @media (min-width: 768px) {
        .wrap {
          padding: 0 48px;
        }
      }
      .wrap-narrow {
        max-width: 980px;
      }

      .section {
        padding: 80px 0;
        position: relative;
      }
      @media (min-width: 768px) {
        .section {
          padding: 120px 0;
        }
      }

      .section-num {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.3em;
        color: var(--gold);
        text-transform: uppercase;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .section-num::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--gold-glow), transparent);
        max-width: 120px;
      }
      .section-title {
        font-family: var(--serif);
        font-weight: 900;
        font-size: clamp(36px, 6vw, 68px);
        line-height: 0.95;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 24px;
        font-variation-settings: 'opsz' 144;
      }
      .section-title em {
        font-style: italic;
        color: var(--gold);
        font-weight: 500;
      }
      .section-title .strike-word {
        color: var(--strike);
        font-style: italic;
        font-weight: 600;
      }
      .section-title .uphold-word {
        color: var(--uphold);
        font-style: italic;
        font-weight: 600;
      }
      .section-lede {
        font-family: var(--serif);
        font-size: 22px;
        line-height: 1.5;
        color: var(--text-mid);
        max-width: 720px;
        margin-bottom: 56px;
        font-variation-settings: 'opsz' 32;
      }
      @media (min-width: 768px) {
        .section-lede {
          font-size: 26px;
        }
      }

      /* ============================================================
         HERO
         ============================================================ */
      .hero {
        min-height: calc(100vh - 40px);
        position: relative;
        background:
          radial-gradient(
            ellipse at top right,
            rgba(212, 168, 42, 0.14),
            transparent 50%
          ),
          radial-gradient(
            ellipse at bottom left,
            rgba(200, 51, 61, 0.08),
            transparent 50%
          ),
          var(--void);
        overflow: hidden;
        display: flex;
        align-items: center;
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          repeating-linear-gradient(
            0deg,
            rgba(244, 241, 232, 0.012) 0,
            rgba(244, 241, 232, 0.012) 1px,
            transparent 1px,
            transparent 3px
          ),
          repeating-linear-gradient(
            90deg,
            rgba(244, 241, 232, 0.012) 0,
            rgba(244, 241, 232, 0.012) 1px,
            transparent 1px,
            transparent 3px
          );
        pointer-events: none;
        mix-blend-mode: overlay;
      }

      .hero::after {
        content: 'IV · III';
        position: absolute;
        right: -2vw;
        bottom: -8vw;
        font-family: var(--serif);
        font-size: clamp(200px, 40vw, 600px);
        font-weight: 900;
        color: rgba(212, 168, 42, 0.04);
        line-height: 1;
        pointer-events: none;
        font-variation-settings: 'opsz' 144;
        letter-spacing: -0.04em;
      }

      .hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 80px 0 60px;
      }

      .hero-eyebrow {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 28px;
        display: inline-flex;
        align-items: center;
        gap: 14px;
      }
      .hero-eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: var(--gold);
      }

      .hero-cite {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 500;
        font-size: clamp(20px, 2.4vw, 30px);
        color: var(--text-mid);
        margin-bottom: 12px;
        font-variation-settings: 'opsz' 48;
      }
      .hero-cite .v {
        color: var(--text-faint);
        margin: 0 8px;
        font-style: normal;
      }

      .hero-title {
        font-family: var(--display);
        font-size: clamp(64px, 14vw, 220px);
        line-height: 0.85;
        letter-spacing: -0.04em;
        color: var(--text);
        margin: 18px 0 0;
        text-transform: uppercase;
      }
      .hero-title .four,
      .hero-title .three {
        display: inline-block;
      }
      .hero-title .dash {
        display: inline-block;
        width: 0.6em;
        height: 0.12em;
        background: var(--gold);
        vertical-align: middle;
        margin: 0 0.08em;
        transform: translateY(-0.15em);
      }
      .hero-title .four {
        color: var(--strike);
        text-shadow: 0 0 60px var(--strike-glow);
      }
      .hero-title .three {
        color: var(--text-mid);
      }

      .hero-subhead {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(22px, 3vw, 38px);
        color: var(--text-mid);
        margin-top: 28px;
        max-width: 800px;
        line-height: 1.25;
        font-variation-settings: 'opsz' 48;
      }
      .hero-subhead strong {
        color: var(--text);
        font-weight: 600;
        font-style: normal;
      }

      .hero-meta {
        margin-top: 56px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      @media (min-width: 768px) {
        .hero-meta {
          grid-template-columns: repeat(4, 1fr);
        }
      }
      .hero-stat {
        padding: 24px 28px;
        border-right: 1px solid var(--border);
      }
      .hero-stat:last-child {
        border-right: none;
      }
      .hero-stat:nth-child(2n) {
        border-right: none;
      }
      @media (min-width: 768px) {
        .hero-stat:nth-child(2n) {
          border-right: 1px solid var(--border);
        }
        .hero-stat:last-child {
          border-right: none;
        }
      }
      .hero-stat-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.25em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      .hero-stat-value {
        font-family: var(--display);
        font-size: 26px;
        line-height: 1.05;
        color: var(--text);
        letter-spacing: -0.01em;
      }
      .hero-stat-value.gold {
        color: var(--gold);
      }
      .hero-stat-value.strike {
        color: var(--strike);
      }
      .hero-stat-sub {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-dim);
        margin-top: 6px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .hero-stamp {
        position: absolute;
        top: 110px;
        right: 24px;
        width: 200px;
        height: 200px;
        border: 3px solid var(--strike);
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transform: rotate(-12deg);
        opacity: 0.92;
        font-family: var(--display);
        color: var(--strike);
        box-shadow:
          inset 0 0 0 6px var(--void),
          inset 0 0 0 7px var(--strike);
        text-align: center;
      }
      .hero-stamp::before,
      .hero-stamp::after {
        content: '';
        position: absolute;
        left: 12%;
        right: 12%;
        height: 1.5px;
        background: var(--strike);
      }
      .hero-stamp::before {
        top: 22%;
      }
      .hero-stamp::after {
        bottom: 22%;
      }
      .hero-stamp-main {
        font-size: 22px;
        letter-spacing: 0.06em;
        line-height: 1;
      }
      .hero-stamp-sub {
        font-size: 9px;
        letter-spacing: 0.18em;
        margin-top: 6px;
        font-family: var(--mono);
      }
      .hero-stamp-tiny {
        font-size: 8px;
        letter-spacing: 0.2em;
        font-family: var(--mono);
        color: var(--strike);
        opacity: 0.7;
        margin-top: 4px;
      }
      @media (max-width: 1100px) {
        .hero-stamp {
          width: 160px;
          height: 160px;
        }
        .hero-stamp-main {
          font-size: 18px;
        }
      }
      @media (max-width: 900px) {
        .hero-stamp {
          position: static;
          margin: 40px auto 0;
          transform: rotate(-6deg);
        }
      }

      /* ============================================================
         VOTE BAR — running tally of predicted votes
         ============================================================ */
      .vote-bar {
        margin-top: 56px;
        padding: 28px 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .vote-bar-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-bottom: 16px;
        display: flex;
        justify-content: space-between;
      }
      .vote-bar-label .left {
        color: var(--strike);
      }
      .vote-bar-label .right {
        color: var(--uphold);
      }
      .vote-track {
        height: 14px;
        background: var(--surface);
        border: 1px solid var(--border);
        position: relative;
        display: flex;
      }
      .vote-track-strike {
        background: linear-gradient(90deg, var(--strike-deep), var(--strike));
        flex: 0 0 calc(100% * 4 / 7);
        position: relative;
      }
      .vote-track-strike::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          45deg,
          transparent 0,
          transparent 6px,
          rgba(0, 0, 0, 0.15) 6px,
          rgba(0, 0, 0, 0.15) 8px
        );
      }
      .vote-track-uphold {
        background: linear-gradient(90deg, var(--uphold), var(--uphold-deep));
        flex: 0 0 calc(100% * 3 / 7);
        position: relative;
      }
      .vote-track-uphold::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          -45deg,
          transparent 0,
          transparent 6px,
          rgba(0, 0, 0, 0.15) 6px,
          rgba(0, 0, 0, 0.15) 8px
        );
      }
      .vote-segment-divider {
        position: absolute;
        top: -6px;
        bottom: -6px;
        left: calc(100% * 4 / 7);
        width: 2px;
        background: var(--gold);
      }
      .vote-segment-divider::before {
        content: '4 / 7';
        position: absolute;
        top: -22px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.18em;
        color: var(--gold);
        white-space: nowrap;
      }
      .vote-bar-totals {
        margin-top: 22px;
        display: flex;
        justify-content: space-between;
        font-family: var(--display);
        font-size: 28px;
      }
      .vote-bar-totals .strike-side {
        color: var(--strike);
      }
      .vote-bar-totals .uphold-side {
        color: var(--uphold);
      }
      .vote-bar-totals .v {
        color: var(--text-faint);
        font-size: 18px;
        font-family: var(--serif);
        font-style: italic;
      }

      /* ============================================================
         BENCH — visual seating arrangement of 7 justices
         ============================================================ */
      .bench-section {
        background: linear-gradient(180deg, var(--void), var(--bg));
        padding: 100px 0 120px;
        border-top: 1px solid var(--border-dim);
        position: relative;
      }
      .bench-arc {
        margin-top: 60px;
        position: relative;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
      }
      .bench-row {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
        align-items: end;
      }
      .bench-seat {
        position: relative;
        text-align: center;
        padding: 14px 6px 18px;
        border-top: 4px solid var(--border);
        background: linear-gradient(180deg, var(--surface), transparent);
        transition:
          transform 0.3s ease,
          border-color 0.3s ease;
      }
      .bench-seat:hover {
        transform: translateY(-6px);
      }
      .bench-seat.strike {
        border-top-color: var(--strike);
      }
      .bench-seat.uphold {
        border-top-color: var(--uphold);
      }
      .bench-seat.tossup {
        border-top-color: var(--tossup);
      }

      /* CJ riser */
      .bench-seat.chief {
        margin-bottom: 0;
        position: relative;
      }
      .bench-seat.chief::before {
        content: 'CHIEF';
        position: absolute;
        top: -32px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.3em;
        color: var(--gold);
      }
      /* Stagger seat heights to mimic an arc */
      .bench-seat.h1 {
        padding-top: 18px;
        padding-bottom: 22px;
      }
      .bench-seat.h2 {
        padding-top: 16px;
        padding-bottom: 20px;
      }
      .bench-seat.h3 {
        padding-top: 14px;
        padding-bottom: 18px;
      }

      .bench-num {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.2em;
        color: var(--text-faint);
        margin-bottom: 8px;
      }
      .bench-portrait {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        margin: 0 auto 10px;
        background: var(--panel);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--display);
        font-size: 20px;
        color: var(--text-mid);
        border: 2px solid var(--border);
        position: relative;
        overflow: hidden;
      }
      .bench-portrait img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 50% 30%;
        filter: grayscale(0.25) contrast(1.05);
      }
      .bench-seat.uphold .bench-portrait img {
        filter: grayscale(0.7) contrast(1.05) brightness(0.85);
      }
      .bench-seat.strike .bench-portrait {
        border-color: var(--strike);
        color: var(--strike);
      }
      .bench-seat.uphold .bench-portrait {
        border-color: var(--uphold);
        color: var(--uphold);
      }
      .bench-seat.tossup .bench-portrait {
        border-color: var(--tossup);
        color: var(--tossup);
      }
      .bench-name {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 13px;
        line-height: 1.15;
        color: var(--text);
        margin-bottom: 6px;
        font-variation-settings: 'opsz' 18;
      }
      .bench-vote {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
      .bench-seat.strike .bench-vote {
        color: var(--strike);
      }
      .bench-seat.uphold .bench-vote {
        color: var(--uphold);
      }
      .bench-seat.tossup .bench-vote {
        color: var(--tossup);
      }

      .bench-floor {
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--border),
          transparent
        );
        margin-top: -1px;
      }
      .bench-legend {
        margin-top: 56px;
        display: flex;
        justify-content: center;
        gap: 28px;
        flex-wrap: wrap;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-dim);
      }
      .bench-legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .bench-legend-dot {
        width: 10px;
        height: 3px;
      }
      .bench-legend-dot.strike {
        background: var(--strike);
      }
      .bench-legend-dot.uphold {
        background: var(--uphold);
      }
      .bench-legend-dot.tossup {
        background: var(--tossup);
      }

      @media (max-width: 720px) {
        .bench-row {
          grid-template-columns: repeat(7, 1fr);
          gap: 4px;
        }
        .bench-portrait {
          width: 40px;
          height: 40px;
          font-size: 14px;
        }
        .bench-name {
          font-size: 10px;
        }
        .bench-vote {
          font-size: 8px;
        }
      }

      /* ============================================================
         TIMELINE — case timeline visualization
         ============================================================ */
      .timeline-section {
        background: var(--bg);
        border-top: 1px solid var(--border-dim);
        border-bottom: 1px solid var(--border-dim);
      }
      .timeline {
        margin-top: 40px;
        position: relative;
      }
      .timeline-track {
        position: relative;
        padding: 60px 0 40px;
      }
      .timeline-line {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--border);
      }
      .timeline-events {
        position: relative;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
      }
      .timeline-event {
        text-align: center;
        position: relative;
      }
      .timeline-dot {
        width: 18px;
        height: 18px;
        background: var(--surface);
        border: 3px solid var(--gold);
        border-radius: 50%;
        margin: 0 auto;
        position: relative;
        z-index: 2;
        transition: transform 0.3s ease;
      }
      .timeline-event.crucial .timeline-dot {
        background: var(--strike);
        border-color: var(--strike);
        box-shadow: 0 0 24px var(--strike-glow);
      }
      .timeline-event.crucial::after {
        content: 'CRITICAL';
        position: absolute;
        top: -22px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.25em;
        color: var(--strike);
        white-space: nowrap;
      }
      .timeline-date {
        margin-top: 22px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--gold);
      }
      .timeline-label {
        margin-top: 8px;
        font-family: var(--serif);
        font-weight: 500;
        font-size: 14px;
        color: var(--text-mid);
        line-height: 1.3;
        font-variation-settings: 'opsz' 18;
      }
      .timeline-event.crucial .timeline-date {
        color: var(--strike);
      }
      .timeline-event.crucial .timeline-label {
        color: var(--text);
        font-weight: 600;
      }

      .timeline-cleavage {
        margin-top: 56px;
        padding: 32px;
        border: 1px solid var(--strike);
        background: linear-gradient(
          135deg,
          rgba(212, 168, 42, 0.06),
          transparent
        );
        position: relative;
      }
      .timeline-cleavage::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--strike);
      }
      .timeline-cleavage-eyebrow {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        color: var(--strike);
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      .timeline-cleavage-text {
        font-family: var(--serif);
        font-size: 22px;
        line-height: 1.4;
        color: var(--text);
        font-variation-settings: 'opsz' 32;
      }
      .timeline-cleavage-text strong {
        color: var(--strike);
        font-weight: 700;
      }

      @media (max-width: 720px) {
        .timeline-events {
          grid-template-columns: 1fr;
          gap: 24px;
        }
        .timeline-line {
          display: none;
        }
        .timeline-event {
          text-align: left;
          padding-left: 28px;
          border-left: 2px solid var(--border);
        }
        .timeline-dot {
          margin: 0;
          position: absolute;
          left: -10px;
          top: 0;
        }
        .timeline-event.crucial::after {
          left: 0;
          transform: none;
        }
      }

      /* ============================================================
         VLAMING BLOC — the central data point
         ============================================================ */
      .vlaming-section {
        background: var(--void);
      }
      .vlaming-quote {
        margin-top: 40px;
        padding: 48px 40px;
        background: var(--surface);
        border: 1px solid var(--border-dim);
        border-left: 4px solid var(--gold);
        position: relative;
      }
      .vlaming-quote-mark {
        position: absolute;
        top: -10px;
        left: 32px;
        font-family: var(--serif);
        font-size: 96px;
        color: var(--gold);
        line-height: 1;
        font-style: italic;
      }
      .vlaming-quote-text {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(20px, 2.4vw, 28px);
        line-height: 1.5;
        color: var(--text);
        font-variation-settings: 'opsz' 48;
        padding-left: 48px;
      }
      .vlaming-quote-cite {
        margin-top: 24px;
        padding-left: 48px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        color: var(--text-dim);
        text-transform: uppercase;
      }
      .vlaming-quote-cite strong {
        color: var(--gold);
      }

      .vlaming-split {
        margin-top: 64px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 4px;
        background: var(--border-dim);
      }
      @media (min-width: 900px) {
        .vlaming-split {
          grid-template-columns: 4fr 3fr;
        }
      }
      .vlaming-side {
        background: var(--surface);
        padding: 36px 32px 32px;
      }
      .vlaming-side.majority {
        border-top: 4px solid var(--strike);
      }
      .vlaming-side.dissent {
        border-top: 4px solid var(--uphold);
      }
      .vlaming-side-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .vlaming-side.majority .vlaming-side-label {
        color: var(--strike);
      }
      .vlaming-side.dissent .vlaming-side-label {
        color: var(--uphold);
      }
      .vlaming-side-count {
        font-family: var(--display);
        font-size: 56px;
        line-height: 1;
        margin-bottom: 18px;
        letter-spacing: -0.03em;
      }
      .vlaming-side.majority .vlaming-side-count {
        color: var(--strike);
      }
      .vlaming-side.dissent .vlaming-side-count {
        color: var(--uphold);
      }
      .vlaming-side-title {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 16px;
        color: var(--text-mid);
        margin-bottom: 16px;
        font-variation-settings: 'opsz' 18;
      }
      .vlaming-names {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .vlaming-name {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: var(--serif);
        font-weight: 600;
        font-size: 16px;
        color: var(--text);
        font-variation-settings: 'opsz' 18;
      }
      .vlaming-name-marker {
        width: 6px;
        height: 22px;
        background: var(--text-faint);
      }
      .vlaming-side.majority .vlaming-name-marker {
        background: var(--strike);
      }
      .vlaming-side.dissent .vlaming-name-marker {
        background: var(--uphold);
      }
      .vlaming-name-meta {
        margin-left: auto;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.15em;
        color: var(--text-faint);
        text-transform: uppercase;
      }
      .vlaming-name.replaced {
        opacity: 0.5;
      }
      .vlaming-name.replaced .vlaming-name-meta {
        color: var(--gold);
      }
      .vlaming-replaced-note {
        margin-top: 16px;
        padding: 12px 14px;
        background: rgba(212, 168, 42, 0.06);
        border-left: 3px solid var(--gold);
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        color: var(--text-mid);
        line-height: 1.5;
      }

      .vlaming-takeaway {
        margin-top: 48px;
        padding: 32px;
        border: 1px dashed var(--gold);
        background: rgba(212, 168, 42, 0.03);
      }
      .vlaming-takeaway-eyebrow {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        color: var(--gold);
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      .vlaming-takeaway-text {
        font-family: var(--serif);
        font-size: clamp(18px, 2vw, 22px);
        line-height: 1.5;
        color: var(--text);
        font-variation-settings: 'opsz' 24;
      }
      .vlaming-takeaway-text em {
        color: var(--gold);
        font-weight: 600;
        font-style: italic;
      }

      /* ============================================================
         JUSTICE CARDS — main content
         ============================================================ */
      .justices-section {
        background: var(--bg);
        position: relative;
      }
      .justices-grid {
        margin-top: 56px;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .justice-card {
        background: var(--surface);
        border: 1px solid var(--border-dim);
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s ease;
      }
      .justice-card:hover {
        border-color: var(--border);
      }
      .justice-card.strike {
        border-left: 4px solid var(--strike);
      }
      .justice-card.uphold {
        border-left: 4px solid var(--uphold);
      }
      .justice-card.tossup {
        border-left: 4px solid var(--tossup);
      }

      .justice-inner {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }
      @media (min-width: 900px) {
        .justice-inner {
          grid-template-columns: 280px 1fr 280px;
        }
      }

      /* LEFT: identity column */
      .justice-id {
        padding: 36px 32px;
        background: linear-gradient(180deg, var(--panel), var(--surface));
        border-bottom: 1px solid var(--border-dim);
      }
      @media (min-width: 900px) {
        .justice-id {
          border-bottom: none;
          border-right: 1px solid var(--border-dim);
        }
      }
      .justice-num {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.3em;
        color: var(--text-faint);
        margin-bottom: 18px;
      }
      .justice-portrait {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--panel-2);
        margin-bottom: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--display);
        font-size: 32px;
        color: var(--text-mid);
        border: 3px solid var(--border);
        overflow: hidden;
      }
      .justice-portrait img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 50% 28%;
        filter: grayscale(0.2) contrast(1.05);
      }
      .justice-card.uphold .justice-portrait img {
        /* Visually mute the uphold votes — they ratify the gerrymander */
        filter: grayscale(0.85) contrast(1.05) brightness(0.78);
      }
      .justice-card.strike .justice-portrait {
        border-color: var(--strike);
        color: var(--strike);
        box-shadow: 0 0 24px rgba(212, 168, 42, 0.18);
        background: linear-gradient(
          135deg,
          rgba(212, 168, 42, 0.12),
          var(--panel-2)
        );
      }
      .justice-card.uphold .justice-portrait {
        border-color: var(--uphold);
        color: var(--uphold);
        background: linear-gradient(
          135deg,
          rgba(200, 51, 61, 0.10),
          var(--panel-2)
        );
      }
      .justice-card.tossup .justice-portrait {
        border-color: var(--tossup);
        color: var(--tossup);
        background: linear-gradient(
          135deg,
          rgba(212, 168, 42, 0.08),
          var(--panel-2)
        );
      }
      .justice-name {
        font-family: var(--serif);
        font-weight: 700;
        font-size: 28px;
        line-height: 1.05;
        color: var(--text);
        margin-bottom: 6px;
        font-variation-settings: 'opsz' 48;
      }
      .justice-suffix {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.25em;
        color: var(--gold);
        text-transform: uppercase;
        margin-bottom: 18px;
      }
      .justice-bio {
        font-family: var(--body);
        font-size: 13px;
        color: var(--text-dim);
        line-height: 1.6;
      }

      /* MIDDLE: analysis */
      .justice-body {
        padding: 36px 32px;
      }
      .justice-section-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 10px;
      }
      .justice-readhead {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 600;
        font-size: 22px;
        line-height: 1.3;
        margin-bottom: 22px;
        font-variation-settings: 'opsz' 32;
      }
      .justice-card.strike .justice-readhead {
        color: var(--text);
      }
      .justice-card.uphold .justice-readhead {
        color: var(--text);
      }
      .justice-card.tossup .justice-readhead {
        color: var(--text);
      }
      .justice-readhead strong.strike-text {
        color: var(--strike);
        font-style: normal;
      }
      .justice-readhead strong.uphold-text {
        color: var(--uphold);
        font-style: normal;
      }
      .justice-readhead strong.tossup-text {
        color: var(--tossup);
        font-style: normal;
      }

      .justice-reasons {
        list-style: none;
        padding: 0;
        margin: 0 0 24px 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .justice-reason {
        position: relative;
        padding-left: 24px;
        font-family: var(--body);
        font-size: 14px;
        color: var(--text-mid);
        line-height: 1.6;
      }
      .justice-reason::before {
        content: '';
        position: absolute;
        left: 0;
        top: 10px;
        width: 14px;
        height: 1px;
        background: var(--gold);
      }

      .justice-flag {
        margin-top: 18px;
        padding: 14px 18px;
        background: var(--panel);
        border-left: 2px solid var(--gold);
        font-family: var(--body);
        font-size: 13px;
        color: var(--text-mid);
        line-height: 1.55;
      }
      .justice-flag-label {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.25em;
        color: var(--gold);
        text-transform: uppercase;
        margin-bottom: 4px;
        display: block;
      }

      /* RIGHT: vote prediction sidebar */
      .justice-verdict {
        padding: 36px 32px;
        background: linear-gradient(180deg, var(--panel-2), var(--surface));
        border-top: 1px solid var(--border-dim);
        display: flex;
        flex-direction: column;
        gap: 22px;
      }
      @media (min-width: 900px) {
        .justice-verdict {
          border-top: none;
          border-left: 1px solid var(--border-dim);
        }
      }
      .verdict-stamp {
        text-align: center;
        padding: 18px 12px;
        border: 2px solid;
        border-radius: 4px;
        position: relative;
      }
      .justice-card.strike .verdict-stamp {
        border-color: var(--strike);
        background: rgba(212, 168, 42, 0.10);
      }
      .justice-card.uphold .verdict-stamp {
        border-color: var(--uphold);
        background: rgba(200, 51, 61, 0.08);
      }
      .justice-card.tossup .verdict-stamp {
        border-color: var(--tossup);
        background: rgba(196, 125, 58, 0.08);
      }
      .verdict-label {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.3em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .verdict-call {
        font-family: var(--display);
        font-size: 32px;
        line-height: 1;
        letter-spacing: 0.02em;
        margin-bottom: 6px;
      }
      .justice-card.strike .verdict-call {
        color: var(--strike);
      }
      .justice-card.uphold .verdict-call {
        color: var(--uphold);
      }
      .justice-card.tossup .verdict-call {
        color: var(--tossup);
      }
      .verdict-confidence {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--text-dim);
        text-transform: uppercase;
      }

      .verdict-meter {
        margin-top: 14px;
        display: flex;
        gap: 4px;
      }
      .verdict-pip {
        flex: 1;
        height: 4px;
        background: var(--border-dim);
      }
      .verdict-pip.on {
        background: var(--text-mid);
      }
      .justice-card.strike .verdict-pip.on {
        background: var(--strike);
      }
      .justice-card.uphold .verdict-pip.on {
        background: var(--uphold);
      }
      .justice-card.tossup .verdict-pip.on {
        background: var(--tossup);
      }

      .verdict-stat {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-dim);
      }
      .verdict-stat:last-child {
        border-bottom: none;
      }
      .verdict-stat-label {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.2em;
        color: var(--text-faint);
        text-transform: uppercase;
      }
      .verdict-stat-value {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 14px;
        color: var(--text);
        text-align: right;
        font-variation-settings: 'opsz' 18;
      }
      .verdict-stat-value.gold {
        color: var(--gold);
      }
      .verdict-stat-value.strike {
        color: var(--strike);
      }
      .verdict-stat-value.uphold {
        color: var(--uphold);
      }

      .verdict-vlaming {
        text-align: center;
        padding: 14px;
        background: var(--bg);
        border: 1px solid var(--border-dim);
      }
      .verdict-vlaming-label {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.25em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-bottom: 4px;
      }
      .verdict-vlaming-value {
        font-family: var(--serif);
        font-weight: 700;
        font-size: 14px;
        color: var(--text);
        font-variation-settings: 'opsz' 18;
      }
      .verdict-vlaming-value.maj {
        color: var(--strike);
      }
      .verdict-vlaming-value.dis {
        color: var(--uphold);
      }
      .verdict-vlaming-value.na {
        color: var(--text-dim);
        font-style: italic;
        font-weight: 400;
      }

      /* ============================================================
         REAPPOINTMENT TIMELINE
         ============================================================ */
      .reapp-section {
        background: var(--void);
      }
      .reapp-bar {
        margin-top: 56px;
        position: relative;
      }
      .reapp-axis {
        height: 1px;
        background: var(--border);
        margin: 60px 0 30px;
        position: relative;
      }
      .reapp-axis-tick {
        position: absolute;
        top: -6px;
        width: 1px;
        height: 12px;
        background: var(--text-faint);
      }
      .reapp-axis-label {
        position: absolute;
        top: 18px;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.15em;
        color: var(--text-faint);
        transform: translateX(-50%);
      }
      .reapp-marker {
        position: absolute;
        top: 0;
        transform: translate(-50%, -100%);
        text-align: center;
        cursor: default;
      }
      .reapp-marker-pin {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        margin: 0 auto;
        background: var(--text-faint);
        border: 2px solid var(--surface);
      }
      .reapp-marker.maximum .reapp-marker-pin {
        background: var(--strike);
        box-shadow:
          0 0 0 4px rgba(212, 168, 42, 0.22),
          0 0 16px var(--strike-glow);
      }
      .reapp-marker.high .reapp-marker-pin {
        background: var(--gold);
        box-shadow: 0 0 0 3px rgba(212, 168, 42, 0.15);
      }
      .reapp-marker-line {
        width: 2px;
        height: 32px;
        margin: 0 auto;
        background: var(--text-faint);
        opacity: 0.4;
      }
      .reapp-marker.maximum .reapp-marker-line {
        background: var(--strike);
        opacity: 0.7;
      }
      .reapp-marker.high .reapp-marker-line {
        background: var(--gold);
        opacity: 0.5;
      }

      .reapp-marker-label {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 13px;
        color: var(--text);
        margin-bottom: 2px;
        white-space: nowrap;
        font-variation-settings: 'opsz' 18;
      }
      .reapp-marker-date {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        color: var(--text-dim);
        white-space: nowrap;
      }
      .reapp-marker-pressure {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-top: 4px;
        white-space: nowrap;
      }
      .reapp-marker.maximum .reapp-marker-pressure {
        color: var(--strike);
      }
      .reapp-marker.high .reapp-marker-pressure {
        color: var(--gold);
      }
      .reapp-marker.low .reapp-marker-pressure,
      .reapp-marker.none .reapp-marker-pressure {
        color: var(--text-faint);
      }

      /* mobile-friendly stacked list */
      .reapp-list {
        display: none;
        flex-direction: column;
        gap: 0;
        margin-top: 30px;
      }
      .reapp-list-item {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 18px;
        padding: 18px 0;
        border-bottom: 1px solid var(--border-dim);
        align-items: center;
      }
      .reapp-list-name {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 16px;
        color: var(--text);
        font-variation-settings: 'opsz' 24;
      }
      .reapp-list-date {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-mid);
      }
      .reapp-list-pressure {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 4px 10px;
        border: 1px solid var(--border);
        border-radius: 2px;
      }
      .reapp-list-pressure.maximum {
        color: var(--strike);
        border-color: var(--strike);
      }
      .reapp-list-pressure.high {
        color: var(--gold);
        border-color: var(--gold);
      }
      .reapp-list-pressure.low {
        color: var(--text-dim);
      }
      .reapp-list-pressure.none {
        color: var(--text-faint);
      }

      @media (max-width: 1100px) {
        .reapp-bar {
          display: none;
        }
        .reapp-list {
          display: flex;
        }
      }

      .reapp-callout {
        margin-top: 64px;
        padding: 32px;
        border: 1px solid var(--border);
        background: var(--surface);
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
      }
      @media (min-width: 768px) {
        .reapp-callout {
          grid-template-columns: 1fr 1fr;
        }
      }
      .reapp-callout-side {
        padding: 0;
      }
      .reapp-callout-eyebrow {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-bottom: 12px;
      }
      .reapp-callout-side.against .reapp-callout-eyebrow {
        color: var(--uphold);
      }
      .reapp-callout-side.for .reapp-callout-eyebrow {
        color: var(--strike);
      }
      .reapp-callout-text {
        font-family: var(--serif);
        font-size: 16px;
        line-height: 1.55;
        color: var(--text-mid);
        font-variation-settings: 'opsz' 18;
      }
      .reapp-callout-text strong {
        color: var(--text);
      }

      /* ============================================================
         SCENARIOS — probability ranking
         ============================================================ */
      .scenarios-section {
        background: linear-gradient(180deg, var(--bg), var(--void));
        border-top: 1px solid var(--border-dim);
      }
      .scenarios {
        margin-top: 56px;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .scenario {
        background: var(--surface);
        border: 1px solid var(--border-dim);
        padding: 28px 32px;
        position: relative;
        transition:
          border-color 0.3s ease,
          transform 0.3s ease;
      }
      .scenario:hover {
        border-color: var(--border);
        transform: translateX(4px);
      }
      .scenario.headline {
        background: linear-gradient(
          135deg,
          rgba(212, 168, 42, 0.10),
          var(--surface)
        );
        border-color: var(--strike);
        box-shadow: inset 0 0 0 1px rgba(212, 168, 42, 0.15);
      }
      .scenario.runner {
        background: linear-gradient(
          135deg,
          rgba(200, 51, 61, 0.08),
          var(--surface)
        );
        border-color: var(--uphold);
      }
      .scenario-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        align-items: start;
      }
      @media (min-width: 900px) {
        .scenario-grid {
          grid-template-columns: 80px 1fr 220px;
          gap: 32px;
          align-items: center;
        }
      }
      .scenario-rank {
        font-family: var(--display);
        font-size: 64px;
        line-height: 1;
        color: var(--text-faint);
        letter-spacing: -0.04em;
      }
      .scenario.headline .scenario-rank {
        color: var(--strike);
      }
      .scenario.runner .scenario-rank {
        color: var(--uphold);
      }
      .scenario-content {
        min-width: 0;
      }
      .scenario-tag {
        display: inline-block;
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        padding: 3px 9px;
        border: 1px solid var(--border);
        color: var(--text-dim);
        margin-bottom: 10px;
      }
      .scenario.headline .scenario-tag {
        color: var(--strike);
        border-color: var(--strike);
      }
      .scenario.runner .scenario-tag {
        color: var(--uphold);
        border-color: var(--uphold);
      }
      .scenario-title {
        font-family: var(--serif);
        font-weight: 700;
        font-size: clamp(20px, 2.4vw, 28px);
        line-height: 1.2;
        color: var(--text);
        margin-bottom: 12px;
        font-variation-settings: 'opsz' 32;
      }
      .scenario-title em {
        color: var(--gold);
        font-style: italic;
        font-weight: 500;
      }
      .scenario-desc {
        font-family: var(--body);
        font-size: 14px;
        color: var(--text-mid);
        line-height: 1.6;
      }
      .scenario-prob {
        text-align: right;
      }
      .scenario-prob-num {
        font-family: var(--display);
        font-size: 64px;
        line-height: 1;
        color: var(--text);
        letter-spacing: -0.03em;
      }
      .scenario.headline .scenario-prob-num {
        color: var(--strike);
      }
      .scenario.runner .scenario-prob-num {
        color: var(--uphold);
      }
      .scenario-prob-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.25em;
        color: var(--text-faint);
        text-transform: uppercase;
        margin-top: 6px;
      }
      .scenario-bar {
        margin-top: 12px;
        height: 4px;
        background: var(--border-dim);
        position: relative;
        overflow: hidden;
      }
      .scenario-bar-fill {
        height: 100%;
        background: var(--text-mid);
      }
      .scenario.headline .scenario-bar-fill {
        background: var(--strike);
      }
      .scenario.runner .scenario-bar-fill {
        background: var(--uphold);
      }

      /* ============================================================
         WILDCARDS
         ============================================================ */
      .wildcards-section {
        background: var(--bg);
        border-top: 1px solid var(--border-dim);
      }
      .wildcards-grid {
        margin-top: 56px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2px;
        background: var(--border-dim);
        border: 1px solid var(--border-dim);
      }
      @media (min-width: 768px) {
        .wildcards-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .wildcard {
        background: var(--surface);
        padding: 32px;
        position: relative;
      }
      .wildcard-num {
        font-family: var(--display);
        font-size: 48px;
        line-height: 1;
        color: var(--gold);
        letter-spacing: -0.04em;
        margin-bottom: 16px;
      }
      .wildcard-title {
        font-family: var(--serif);
        font-weight: 700;
        font-size: 20px;
        color: var(--text);
        margin-bottom: 12px;
        font-variation-settings: 'opsz' 24;
      }
      .wildcard-text {
        font-family: var(--body);
        font-size: 14px;
        color: var(--text-mid);
        line-height: 1.6;
      }

      /* ============================================================
         WATCH LIST
         ============================================================ */
      .watch-section {
        background: var(--void);
      }
      .watch-list {
        margin-top: 48px;
        list-style: none;
        padding: 0;
      }
      .watch-item {
        display: grid;
        grid-template-columns: 60px 1fr;
        gap: 24px;
        padding: 28px 0;
        border-bottom: 1px solid var(--border-dim);
        align-items: start;
      }
      .watch-item:last-child {
        border-bottom: none;
      }
      .watch-num {
        font-family: var(--display);
        font-size: 24px;
        line-height: 1;
        color: var(--gold);
      }
      .watch-content {
        padding-top: 4px;
      }
      .watch-title {
        font-family: var(--serif);
        font-weight: 700;
        font-size: 20px;
        color: var(--text);
        margin-bottom: 6px;
        font-variation-settings: 'opsz' 24;
      }
      .watch-desc {
        font-family: var(--body);
        font-size: 14px;
        color: var(--text-mid);
        line-height: 1.6;
      }

      /* ============================================================
         FOOTER
         ============================================================ */
      .footer-section {
        background: var(--void);
        padding: 80px 0 60px;
        border-top: 1px solid var(--border-dim);
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
      }
      @media (min-width: 900px) {
        .footer-grid {
          grid-template-columns: 2fr 1fr;
        }
      }
      .footer-meth {
        font-family: var(--body);
        font-size: 14px;
        color: var(--text-dim);
        line-height: 1.7;
      }
      .footer-meth strong {
        color: var(--text-mid);
        font-weight: 600;
      }
      .footer-links {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-faint);
        line-height: 2.2;
      }
      .footer-links a {
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.15s ease;
        display: block;
      }
      .footer-links a:hover {
        color: var(--gold);
      }
      .footer-bottom {
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid var(--border-dim);
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        color: var(--text-faint);
        text-transform: uppercase;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
      }
      .footer-bottom a {
        color: var(--gold);
      }

      /* ============================================================
         REVEAL ANIMATIONS
         ============================================================ */
      [data-reveal] {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.9s cubic-bezier(0.2, 0.6, 0.2, 1),
          transform 0.9s cubic-bezier(0.2, 0.6, 0.2, 1);
      }
      [data-reveal].in {
        opacity: 1;
        transform: translateY(0);
      }
      [data-reveal][data-delay='1'] {
        transition-delay: 0.08s;
      }
      [data-reveal][data-delay='2'] {
        transition-delay: 0.16s;
      }
      [data-reveal][data-delay='3'] {
        transition-delay: 0.24s;
      }
      [data-reveal][data-delay='4'] {
        transition-delay: 0.32s;
      }
      [data-reveal][data-delay='5'] {
        transition-delay: 0.4s;
      }
    </style>
  </head>
