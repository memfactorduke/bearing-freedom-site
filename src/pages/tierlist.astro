    // ═══════════════════════════════════════════════
    //  STATE
    // ═══════════════════════════════════════════════
    let selectedId = null;
    let dragEl = null;

    // ═══════════════════════════════════════════════
    //  CREATE TILE
    // ═══════════════════════════════════════════════
    function createTile(bill, delay) {
      const el = document.createElement('div');
      el.className = 'tile';
      el.dataset.id = bill.id;
      el.dataset.cat = bill.cat;
      el.draggable = true;
      // No stagger — all tiles appear instantly
      el.innerHTML = `<div class="tile-number">${bill.number}</div><div class="tile-nick">${bill.nick}</div>`;

      el.addEventListener('click', (e) => {
        e.stopPropagation();
        selectBill(bill.id);
      });
      el.addEventListener('dragstart', onDragStart);
      el.addEventListener('dragend', onDragEnd);
      el.addEventListener('touchstart', onTouchStart, { passive: false });
      return el;
    }

    // ═══════════════════════════════════════════════
    //  INFO PANEL
    // ═══════════════════════════════════════════════
    function selectBill(id) {
      const bill = BILLS.find(b => b.id === id);
      if (!bill) return;
      selectedId = id;

      document.querySelectorAll('.tile').forEach(t => t.classList.remove('selected'));
      document.querySelectorAll(`.tile[data-id="${id}"]`).forEach(t => t.classList.add('selected'));

      document.getElementById('panel-empty').style.display = 'none';
      const d = document.getElementById('detail');
      d.className = 'detail visible';

      d.innerHTML = `
        <div class="detail-badge" data-cat="${bill.cat}">${bill.catLabel}</div>
        <div class="detail-number">${bill.number}</div>
        ${bill.companion ? `<div class="detail-companion">Companion: ${bill.companion}</div>` : ''}
        <div class="detail-title">${bill.nick}</div>

        <div class="detail-meta">
          <div class="detail-meta-item">
            <span class="detail-meta-label">Effective</span>
            <span class="detail-meta-value">${bill.effective}</span>
          </div>
          <div class="detail-meta-item">
            <span class="detail-meta-label">Status</span>
            <span class="detail-meta-value">${bill.status}</span>
          </div>
        </div>

        <div class="detail-section">
          <div class="detail-section-label">Summary</div>
          <p>${bill.summary}</p>
        </div>

        <div class="detail-section">
          <div class="detail-section-label">Key Provisions</div>
          <ul>${bill.provisions.map(p => `<li>${p}</li>`).join('')}</ul>
        </div>

        <div class="detail-section">
          <div class="detail-section-label">Penalty</div>
          <div class="detail-penalty">${bill.penalty}</div>
        </div>

        <div class="detail-section">
          <div class="detail-section-label">Sponsors</div>
          <div class="detail-sponsors">${bill.sponsors}</div>
        </div>
      `;

      // Mobile
      if (window.innerWidth <= 1100) {
        document.getElementById('panel').classList.add('mobile-open');
      }
    }

    document.getElementById('panel-close')?.addEventListener('click', () => {
      document.getElementById('panel').classList.remove('mobile-open');
    });

    // Deselect
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.tile') && !e.target.closest('.panel')) {
        selectedId = null;
        document.querySelectorAll('.tile').forEach(t => t.classList.remove('selected'));
        document.getElementById('panel-empty').style.display = 'flex';
        document.getElementById('detail').className = 'detail';
      }
    });

    // ═══════════════════════════════════════════════
    //  POOL COUNT
    // ═══════════════════════════════════════════════
    function updatePoolCount() {
      const n = document.getElementById('pool').children.length;
      document.getElementById('pool-count').textContent = n + ' bill' + (n !== 1 ? 's' : '');
    }

    // ═══════════════════════════════════════════════
    //  DRAG & DROP — indicator-based, no DOM shift
    // ═══════════════════════════════════════════════

    // Insertion indicator line
    const indicator = document.createElement('div');
    indicator.style.cssText = 'width:3px;height:70px;background:var(--red);border-radius:2px;flex-shrink:0;pointer-events:none;display:none;margin:0 -2px;';

    let dragOriginParent = null;
    let dragOriginNext = null;

    function onDragStart(e) {
      dragEl = e.target.closest('.tile');
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', dragEl.dataset.id);

      // Remember original position in case drag is cancelled
      dragOriginParent = dragEl.parentElement;
      dragOriginNext = dragEl.nextElementSibling;

      // Hide the tile after browser captures drag image
      requestAnimationFrame(() => {
        dragEl.style.display = 'none';
      });
    }

    function onDragEnd() {
      // Remove indicator
      indicator.style.display = 'none';
      if (indicator.parentElement) indicator.remove();

      if (dragEl) {
        // If tile was never dropped (drag cancelled), restore it
        if (dragEl.style.display === 'none') {
          dragEl.style.display = '';
          if (!dragEl.parentElement) {
            if (dragOriginNext) {
              dragOriginParent.insertBefore(dragEl, dragOriginNext);
            } else {
              dragOriginParent.appendChild(dragEl);
            }
          }
        }
        dragEl.style.display = '';
      }
      dragEl = null;
      dragOriginParent = null;
      dragOriginNext = null;
      document.querySelectorAll('.drag-over').forEach(z => z.classList.remove('drag-over'));
      updatePoolCount();
    }

    function getInsertTarget(zone, x) {
      const tiles = [...zone.querySelectorAll('.tile')];
      if (!tiles.length) return null;
      for (const tile of tiles) {
        const r = tile.getBoundingClientRect();
        if (x < r.left + r.width / 2) return tile;
      }
      return null;
    }

    // Resolve the actual drop zone from any element (handles clicking
    // on tier-row, tier-label, or the drop zone itself)
    function resolveZone(el) {
      if (!el) return null;
      const zone = el.closest('[data-zone]');
      if (zone) return zone;
      // If we hit a tier-row but not the drop zone, use its drop zone
      const row = el.closest('.tier-row');
      if (row) return row.querySelector('[data-zone]');
      return null;
    }

    function handleDragOver(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const zone = resolveZone(e.target);
      if (!zone) return;

      // Clear old highlights
      document.querySelectorAll('.drag-over').forEach(z => {
        if (z !== zone) z.classList.remove('drag-over');
      });
      zone.classList.add('drag-over');

      // Show indicator at insertion point
      const target = getInsertTarget(zone, e.clientX);
      indicator.style.display = '';
      if (target) {
        zone.insertBefore(indicator, target);
      } else {
        zone.appendChild(indicator);
      }
    }

    function handleDrop(e) {
      e.preventDefault();
      const zone = resolveZone(e.target);
      document.querySelectorAll('.drag-over').forEach(z => z.classList.remove('drag-over'));
      if (!dragEl) return;

      dragEl.style.display = '';
      if (indicator.parentElement) {
        indicator.parentElement.insertBefore(dragEl, indicator);
      } else if (zone) {
        zone.appendChild(dragEl);
      }
      indicator.style.display = 'none';
      if (indicator.parentElement) indicator.remove();
      updatePoolCount();
    }

    function handleDragLeave(e) {
      const zone = resolveZone(e.target);
      if (!zone) return;
      // Only remove highlight if we truly left the zone
      const related = resolveZone(e.relatedTarget);
      if (related !== zone) {
        zone.classList.remove('drag-over');
        if (indicator.parentElement === zone) {
          indicator.style.display = 'none';
          indicator.remove();
        }
      }
    }

    function setupDropZones() {
      // Listen on the entire tier area + pool so events never get missed
      const tierArea = document.querySelector('.tier-area');
      tierArea.addEventListener('dragover', handleDragOver);
      tierArea.addEventListener('drop', handleDrop);
      tierArea.addEventListener('dragleave', handleDragLeave);
    }

    // ═══════════════════════════════════════════════
    //  TOUCH DRAG
    // ═══════════════════════════════════════════════
    let touchEl = null, touchGhost = null, tox = 0, toy = 0;

    function onTouchStart(e) {
      const tile = e.target.closest('.tile');
      if (!tile) return;
      const t = e.touches[0], r = tile.getBoundingClientRect();
      tox = t.clientX - r.left;
      toy = t.clientY - r.top;

      tile._tt = setTimeout(() => {
        e.preventDefault();
        touchEl = tile;
        tile.classList.add('dragging');
        touchGhost = tile.cloneNode(true);
        touchGhost.className = 'tile drag-ghost';
        touchGhost.dataset.cat = tile.dataset.cat;
        touchGhost.style.width = r.width + 'px';
        touchGhost.style.height = r.height + 'px';
        touchGhost.style.left = (t.clientX - tox) + 'px';
        touchGhost.style.top = (t.clientY - toy) + 'px';
        document.body.appendChild(touchGhost);
        document.addEventListener('touchmove', onTouchMove, { passive: false });
        document.addEventListener('touchend', onTouchEnd);
      }, 200);
    }

    function onTouchMove(e) {
      if (!touchEl) return;
      e.preventDefault();
      const t = e.touches[0];
      if (touchGhost) {
        touchGhost.style.left = (t.clientX - tox) + 'px';
        touchGhost.style.top = (t.clientY - toy) + 'px';
      }
      document.querySelectorAll('.drag-over').forEach(z => z.classList.remove('drag-over'));
      if (touchGhost) touchGhost.style.display = 'none';
      const el = document.elementFromPoint(t.clientX, t.clientY);
      if (touchGhost) touchGhost.style.display = '';
      const zone = resolveZone(el);
      if (zone) {
        document.querySelectorAll('.drag-over').forEach(z => { if (z !== zone) z.classList.remove('drag-over'); });
        zone.classList.add('drag-over');
        const target = getInsertTarget(zone, t.clientX);
        indicator.style.display = '';
        if (target) {
          zone.insertBefore(indicator, target);
        } else {
          zone.appendChild(indicator);
        }
      }
    }

    function onTouchEnd(e) {
      if (touchEl?._tt) clearTimeout(touchEl._tt);
      if (!touchEl) return;

      // Insert at indicator position
      if (indicator.parentElement) {
        indicator.parentElement.insertBefore(touchEl, indicator);
      }
      indicator.style.display = 'none';
      if (indicator.parentElement) indicator.remove();

      touchEl.classList.remove('dragging');
      if (touchGhost) touchGhost.remove();
      document.querySelectorAll('.drag-over').forEach(z => z.classList.remove('drag-over'));
      touchEl = null; touchGhost = null;
      document.removeEventListener('touchmove', onTouchMove);
      document.removeEventListener('touchend', onTouchEnd);
      updatePoolCount();
    }

    document.addEventListener('touchmove', (e) => {
      const tile = e.target.closest('.tile');
      if (tile?._tt && !touchEl) clearTimeout(tile._tt);
    }, { passive: true });

    // ═══════════════════════════════════════════════
    //  CONTROLS
    // ═══════════════════════════════════════════════
    document.getElementById('btn-reset')?.addEventListener('click', () => {
      const pool = document.getElementById('pool');
      document.querySelectorAll('.tile').forEach(t => pool.appendChild(t));
      updatePoolCount();
    });

    function toggleCleanView() {
      document.body.classList.toggle('ss-mode');
      const btn = document.getElementById('btn-ss');
      btn.textContent = document.body.classList.contains('ss-mode') ? 'Exit Clean View' : 'Clean View';
      btn.classList.toggle('active');
    }

    document.getElementById('btn-ss')?.addEventListener('click', toggleCleanView);
    document.getElementById('btn-exit-ss')?.addEventListener('click', toggleCleanView);

    // ═══════════════════════════════════════════════
    //  INIT
    // ═══════════════════════════════════════════════
    // Default display order
    const BILL_ORDER = [
      'hb217',   // Assault Weapons Ban
      'hb916',   // CHP Class Overhaul
      'hb40',    // Ghost Gun Ban
      'hb1525',  // Permit to Purchase
      'hb1524',  // Public Carry Ban
      'hb21',    // Lawsuit Machine
      'hb19',    // Dating Gun Ban
      'sb115',   // CHP Reciprocity Kill
      'hb702',   // Mandatory Buybacks
      'hb901',   // Red Flag Expansion
      'hb93',    // Gun Surrender
      'hb626',   // Campus Carry Ban
      'hb969',   // Gun Control Center
      'hb871',   // Secure Storage
      'hb110',   // Vehicle Gun Ban
      'hb229',   // Hospital Gun Ban
      'hb909',   // Polling Place Ban
    ];

    const orderedBills = BILL_ORDER.map(id => BILLS.find(b => b.id === id)).filter(Boolean);
    const pool = document.getElementById('pool');
    orderedBills.forEach(bill => {
      pool.appendChild(createTile(bill, 0));
    });
    setupDropZones();
    updatePoolCount();
    </script>
  </body>
</html>
