---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const allStates = [...new Set(articles.flatMap((a) => a.data.states))];

  return allStates.map((state) => {
    const slug = state.toLowerCase().replace(/\s+/g, '-');
    return {
      params: { state: slug },
      props: {
        stateName: state,
        articles: articles
          .filter((a) => a.data.states.includes(state))
          .sort((a, b) => {
            const d = b.data.date.localeCompare(a.data.date);
            return d !== 0
              ? d
              : (a.data.sort_index ?? 9999) - (b.data.sort_index ?? 9999);
          }),
      },
    };
  });
}

const { stateName, articles } = Astro.props;
---

<BaseLayout
  title={stateName}
  description={`Second Amendment coverage in ${stateName}`}
>
  <div class="bg-surface border-b border-border">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
      <nav
        class="text-xs text-text-muted mb-4 flex items-center gap-2 animate-fade-in font-[JetBrains_Mono]"
      >
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <svg
          class="w-3 h-3 text-text-muted/40"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"></path></svg
        >
        <span>States</span>
        <svg
          class="w-3 h-3 text-text-muted/40"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"></path></svg
        >
        <span class="text-text-secondary">{stateName}</span>
      </nav>
      <h1
        class="font-[Archivo_Black] text-3xl font-bold text-text tracking-tight animate-fade-up"
      >
        {stateName}
      </h1>
      <p
        class="text-text-secondary mt-2 text-sm font-[JetBrains_Mono] animate-fade-up stagger-1"
      >
        {articles.length} article{articles.length !== 1 ? 's' : ''}
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7">
      {
        articles.map((article, i) => (
          <div data-animate class={`stagger-${Math.min(i + 1, 6)}`}>
            <ArticleCard
              title={article.data.title}
              date={article.data.date}
              slug={article.id}
              thumbnail={article.data.thumbnail}
              duration={article.data.duration}
              topics={article.data.topics}
              content_type={article.data.content_type}
            />
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>
