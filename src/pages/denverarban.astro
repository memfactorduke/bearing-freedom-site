---
// Standalone page — self-contained styles, no global.css
// Denver AR-15 Ban — DRMC § 38-130 — and U.S. v. Denver (filed 2026-05-05)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Denver AR-15 Ban (DRMC § 38-130) — DOJ v. Denver | Bearing Freedom
    </title>
    <meta
      name="description"
      content="Denver's 37-year-old assault-weapon ban is now the target of a federal lawsuit. DRMC § 38-130, the Article XX home-rule fight, Robertson v. Denver, SB21-256, and U.S. v. Denver — filed 5 May 2026. The full case file."
    />
    <meta
      property="og:title"
      content="Denver AR-15 Ban — DOJ v. Denver | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="DOJ sued Denver over its 1989 assault-weapon ban on May 5, 2026. Mayor Johnston: 'Hell no.' Full case file with the ordinance, Article XX, Robertson, SB21-256, and the federal complaint."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bearingfreedom.com/denverarban" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q6WRV03TTZ"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-Q6WRV03TTZ', {
        send_page_view: true,
        allow_google_signals: true,
        allow_ad_personalization_signals: true,
        cookie_flags: 'SameSite=None;Secure',
        page_referrer: document.referrer,
        screen_resolution: window.screen.width + 'x' + window.screen.height,
      });
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;700;800;900&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        /* Cold alpine night */
        --bg: #0b1117;
        --bg-2: #121d29;
        --bg-3: #1a2735;
        --panel: #1e2c3a;
        --panel-soft: #243345;
        --panel-up: #2c3f54;

        /* Rules / borders */
        --rule: #243345;
        --rule-bright: #3a526a;
        --rule-glow: rgba(122, 163, 200, 0.25);

        /* Text */
        --ink: #ecf1f7;
        --ink-soft: #c8d3e0;
        --ink-mid: #95a4b6;
        --ink-faint: #5e6e80;
        --ink-ghost: rgba(236, 241, 247, 0.06);

        /* Accents */
        --crimson: #d1232a;
        --crimson-deep: #8e1117;
        --crimson-glow: rgba(209, 35, 42, 0.45);
        --crimson-soft: rgba(209, 35, 42, 0.12);
        --crimson-tint: rgba(209, 35, 42, 0.04);

        --gold: #d4a82a;
        --gold-deep: #9a7a17;
        --gold-soft: rgba(212, 168, 42, 0.14);
        --gold-tint: rgba(212, 168, 42, 0.05);

        --mountain: #3d4f63;
        --mountain-back: #243345;
        --snow: #ffffff;

        /* Type */
        --display: 'Big Shoulders Display', 'Impact', sans-serif;
        --body: 'Spectral', Georgia, 'Times New Roman', serif;
        --mono: 'Space Mono', 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
        background: var(--bg);
      }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        background-image:
          radial-gradient(
            ellipse at top,
            rgba(58, 82, 106, 0.12) 0%,
            transparent 60%
          ),
          radial-gradient(
            ellipse at 80% 30%,
            rgba(209, 35, 42, 0.04) 0%,
            transparent 50%
          );
        background-attachment: fixed;
      }

      /* Subtle film grain */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1000;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        mix-blend-mode: overlay;
      }

      a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--gold);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: color 0.15s ease;
      }
      a:hover {
        color: var(--gold);
      }

      ::selection {
        background: var(--crimson);
        color: var(--snow);
      }

      /* ─── ALERT TICKER (Top) ─────────────────────────── */
      .alert-strip {
        background: var(--crimson-deep);
        border-bottom: 1px solid var(--crimson);
        position: relative;
        overflow: hidden;
      }
      .alert-strip::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          90deg,
          transparent 0,
          transparent 2px,
          rgba(255, 255, 255, 0.04) 2px,
          rgba(255, 255, 255, 0.04) 3px
        );
        pointer-events: none;
      }
      .alert-row {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 9px 24px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--snow);
        position: relative;
        z-index: 1;
      }
      .alert-pulse {
        display: inline-block;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--snow);
        box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
        animation: pulse 1.6s infinite;
        flex-shrink: 0;
      }
      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
        }
        70% {
          box-shadow: 0 0 0 14px rgba(255, 255, 255, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
        }
      }
      .alert-text {
        font-weight: 700;
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .alert-text strong {
        color: var(--gold);
        font-weight: 700;
      }
      .alert-stamp {
        opacity: 0.85;
        flex-shrink: 0;
      }

      /* ─── NAV ─────────────────────────── */
      .topbar {
        background: var(--bg-2);
        border-bottom: 1px solid var(--rule);
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(8px);
        background: rgba(11, 17, 23, 0.92);
      }
      .brand {
        font-family: var(--display);
        font-weight: 900;
        font-size: 22px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink);
        text-decoration: none;
      }
      .brand-mark {
        color: var(--crimson);
      }
      .nav-meta {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        color: var(--ink-mid);
        text-transform: uppercase;
        display: flex;
        gap: 14px;
        align-items: center;
      }
      .nav-meta a {
        color: var(--ink-mid);
        text-decoration: none;
      }
      .nav-meta a:hover {
        color: var(--gold);
      }
      .dot {
        width: 4px;
        height: 4px;
        background: var(--ink-faint);
        border-radius: 50%;
      }

      /* ─── HERO ─────────────────────────── */
      .hero {
        position: relative;
        padding: 70px 24px 0;
        overflow: hidden;
        border-bottom: 1px solid var(--rule);
      }
      .hero-mountains {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        width: 100%;
        height: 320px;
        pointer-events: none;
        opacity: 0.35;
      }
      .hero-mountains svg {
        width: 100%;
        height: 100%;
        display: block;
      }
      .hero-inner {
        max-width: 1280px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
      }
      .hero-eyebrow {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--crimson);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .hero-eyebrow::before,
      .hero-eyebrow::after {
        content: '';
        height: 1px;
        background: var(--crimson);
        flex: 1;
        max-width: 60px;
      }

      .hero-headline {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(66px, 12vw, 180px);
        line-height: 0.84;
        letter-spacing: -0.025em;
        text-transform: uppercase;
        color: var(--ink);
        margin-bottom: 22px;
      }
      .hero-headline .word {
        display: block;
      }
      .hero-headline .word.ghost {
        color: transparent;
        -webkit-text-stroke: 1.5px var(--ink-faint);
      }
      .hero-headline .word.crimson {
        color: var(--crimson);
      }
      .hero-headline .word.gold {
        color: var(--gold);
      }

      .hero-deck {
        font-family: var(--body);
        font-size: clamp(18px, 1.6vw, 22px);
        line-height: 1.55;
        font-weight: 500;
        color: var(--ink-soft);
        max-width: 760px;
        margin-bottom: 42px;
        font-style: italic;
      }
      .hero-deck em {
        color: var(--gold);
        font-style: normal;
        font-weight: 600;
      }

      .hero-counters {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border-top: 1px solid var(--rule-bright);
        border-bottom: 1px solid var(--rule-bright);
        margin: 0 0 60px;
      }
      .hero-counter {
        padding: 26px 24px;
        border-right: 1px solid var(--rule);
        position: relative;
      }
      .hero-counter:last-child {
        border-right: none;
      }
      .hero-counter-num {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(40px, 5vw, 68px);
        line-height: 0.95;
        color: var(--ink);
        margin-bottom: 6px;
        letter-spacing: -0.02em;
      }
      .hero-counter-num.crimson {
        color: var(--crimson);
      }
      .hero-counter-num.gold {
        color: var(--gold);
      }
      .hero-counter-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-mid);
      }
      @media (max-width: 720px) {
        .hero-counters {
          grid-template-columns: repeat(2, 1fr);
        }
        .hero-counter {
          border-right: 1px solid var(--rule);
          border-bottom: 1px solid var(--rule);
        }
        .hero-counter:nth-child(2),
        .hero-counter:last-child {
          border-right: none;
        }
        .hero-counter:nth-last-child(-n + 2) {
          border-bottom: none;
        }
      }

      /* ─── SECTION SCAFFOLDING ─────────────────────────── */
      section.chapter {
        padding: 90px 24px;
        border-bottom: 1px solid var(--rule);
        position: relative;
      }
      section.chapter.alt {
        background: var(--bg-2);
      }
      .chapter-inner {
        max-width: 1180px;
        margin: 0 auto;
      }
      .chapter-header {
        display: flex;
        align-items: baseline;
        gap: 28px;
        padding-bottom: 22px;
        margin-bottom: 50px;
        border-bottom: 1px solid var(--rule-bright);
        flex-wrap: wrap;
      }
      .chapter-num {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(46px, 5.5vw, 72px);
        line-height: 1;
        color: transparent;
        -webkit-text-stroke: 1.5px var(--gold);
        letter-spacing: -0.02em;
      }
      .chapter-eyebrow {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 6px;
      }
      .chapter-title {
        font-family: var(--display);
        font-weight: 800;
        font-size: clamp(34px, 4.5vw, 58px);
        line-height: 0.96;
        color: var(--ink);
        text-transform: uppercase;
        letter-spacing: -0.01em;
        flex: 1;
        min-width: 280px;
      }

      .chapter-lede {
        font-family: var(--body);
        font-size: 21px;
        line-height: 1.6;
        color: var(--ink-soft);
        max-width: 820px;
        font-weight: 500;
        margin-bottom: 40px;
      }
      .chapter-lede em {
        color: var(--gold);
        font-style: normal;
      }

      p.body {
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.78;
        color: var(--ink-soft);
        max-width: 760px;
        margin-bottom: 22px;
      }
      p.body strong {
        color: var(--ink);
        font-weight: 600;
      }
      p.body em {
        color: var(--gold);
        font-style: italic;
      }

      h3.sub {
        font-family: var(--display);
        font-weight: 800;
        font-size: 28px;
        text-transform: uppercase;
        letter-spacing: 0.01em;
        color: var(--ink);
        margin: 36px 0 18px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--rule);
      }
      h3.sub::before {
        content: '§';
        color: var(--gold);
        font-weight: 400;
        margin-right: 10px;
      }

      /* ─── OPENING SALVO BLOCK ─────────────────────────── */
      .salvo {
        max-width: 880px;
        margin: 0 auto;
        padding: 80px 24px 90px;
        border-bottom: 1px solid var(--rule);
        position: relative;
      }
      .salvo::before {
        content: '';
        position: absolute;
        top: 70px;
        left: 24px;
        width: 64px;
        height: 4px;
        background: var(--crimson);
      }
      .salvo-eyebrow {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--crimson);
        margin-bottom: 14px;
        padding-top: 18px;
      }
      .salvo p {
        font-family: var(--body);
        font-size: 22px;
        line-height: 1.55;
        color: var(--ink);
        margin-bottom: 24px;
        font-weight: 400;
      }
      .salvo p:first-of-type::first-letter {
        font-family: var(--display);
        font-weight: 900;
        font-size: 92px;
        line-height: 0.85;
        float: left;
        margin: 6px 14px 0 0;
        color: var(--crimson);
      }
      .salvo p strong {
        color: var(--ink);
        font-weight: 600;
        background: linear-gradient(transparent 60%, var(--gold-soft) 60%);
      }
      .salvo p em {
        color: var(--gold);
        font-style: italic;
      }

      /* ─── DOCKET CAPTION (boxing-poster header) ─────────── */
      .docket {
        background: var(--bg-2);
        border-top: 4px solid var(--crimson);
        border-bottom: 4px solid var(--crimson);
        padding: 50px 24px;
      }
      .docket-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 40px;
        align-items: center;
        text-align: center;
      }
      @media (max-width: 760px) {
        .docket-inner {
          grid-template-columns: 1fr;
        }
      }
      .docket-side {
        text-align: center;
      }
      .docket-label {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--ink-mid);
        margin-bottom: 14px;
      }
      .docket-name {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(34px, 5vw, 64px);
        line-height: 0.95;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        color: var(--ink);
      }
      .docket-name.crimson {
        color: var(--crimson);
      }
      .docket-name.gold {
        color: var(--gold);
      }
      .docket-tag {
        font-family: var(--body);
        font-size: 14px;
        font-style: italic;
        color: var(--ink-mid);
        margin-top: 10px;
      }
      .docket-vs {
        font-family: var(--display);
        font-weight: 900;
        font-size: clamp(30px, 4vw, 56px);
        color: var(--gold);
        text-transform: uppercase;
        line-height: 1;
        padding: 0 18px;
        border-left: 1px solid var(--rule);
        border-right: 1px solid var(--rule);
      }
      @media (max-width: 760px) {
        .docket-vs {
          border: none;
          padding: 8px 0;
        }
      }
      .docket-meta {
        max-width: 1100px;
        margin: 24px auto 0;
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
        justify-content: center;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-mid);
      }
      .docket-meta span strong {
        color: var(--ink);
        font-weight: 700;
      }

      /* ─── FACT GRID ─────────────────────────── */
      .fact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0;
        border: 1px solid var(--rule);
        background: var(--panel);
        margin-bottom: 36px;
      }
      .fact {
        padding: 22px 24px;
        border-right: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }
      .fact-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-mid);
        margin-bottom: 8px;
      }
      .fact-value {
        font-family: var(--body);
        font-weight: 600;
        font-size: 17px;
        color: var(--ink);
        line-height: 1.4;
      }
      .fact-value small {
        display: block;
        font-weight: 400;
        font-size: 13px;
        color: var(--ink-mid);
        margin-top: 4px;
        font-style: italic;
      }

      /* ─── STATUTE / CODE BLOCK ─────────────────────── */
      .statute {
        background: linear-gradient(180deg, var(--bg-3), var(--bg-2));
        border: 1px solid var(--rule-bright);
        border-left: 4px solid var(--gold);
        padding: 32px 28px;
        margin: 32px 0;
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.85;
        color: var(--ink-soft);
        position: relative;
        overflow-x: auto;
      }
      .statute::before {
        content: 'DRMC § 38-130';
        position: absolute;
        top: -1px;
        right: 18px;
        background: var(--gold);
        color: var(--bg);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        padding: 4px 10px;
        text-transform: uppercase;
      }
      .statute-line {
        display: flex;
        gap: 18px;
      }
      .statute-num {
        color: var(--ink-faint);
        font-size: 12px;
        flex-shrink: 0;
        width: 30px;
        text-align: right;
        user-select: none;
      }
      .statute-text {
        flex: 1;
      }
      .statute-text b {
        color: var(--gold);
        font-weight: 700;
      }
      .statute-text .strike {
        text-decoration: line-through;
        text-decoration-color: var(--crimson);
        color: var(--ink-faint);
      }
      .statute-text .marker {
        background: var(--crimson-soft);
        color: var(--ink);
        padding: 0 4px;
      }

      /* ─── BAN / EXEMPT CARDS ───────────────────────────── */
      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin: 32px 0;
      }
      @media (max-width: 760px) {
        .two-col {
          grid-template-columns: 1fr;
        }
      }
      .col-card {
        background: var(--panel);
        border: 1px solid var(--rule-bright);
        padding: 28px 26px;
      }
      .col-card.crimson {
        border-color: var(--crimson-deep);
        box-shadow: inset 4px 0 0 var(--crimson);
      }
      .col-card.gold {
        border-color: var(--gold-deep);
        box-shadow: inset 4px 0 0 var(--gold);
      }
      .col-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--rule);
      }
      .col-head-num {
        font-family: var(--display);
        font-weight: 900;
        font-size: 36px;
        line-height: 1;
        color: var(--crimson);
      }
      .col-card.gold .col-head-num {
        color: var(--gold);
      }
      .col-head-text {
        font-family: var(--display);
        font-weight: 800;
        font-size: 22px;
        text-transform: uppercase;
        letter-spacing: 0.01em;
        color: var(--ink);
      }
      .col-list {
        list-style: none;
        padding: 0;
      }
      .col-list li {
        font-family: var(--body);
        font-size: 16px;
        line-height: 1.55;
        color: var(--ink-soft);
