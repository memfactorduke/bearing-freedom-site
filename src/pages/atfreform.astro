        color: var(--red);
        font-weight: 400;
      }

      /* ═════════════════════════════════════════ */
      /* WHAT WAS KEPT — warning section            */
      /* ═════════════════════════════════════════ */
      .kept-shell {
        background: var(--amber-bg);
        border: 2px solid var(--amber-deep);
        position: relative;
        padding: 36px 36px 28px;
      }
      .kept-shell::before {
        content: '';
        position: absolute;
        inset: 6px;
        border: 1px solid var(--amber-deep);
        pointer-events: none;
      }
      .kept-banner {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 22px;
        padding-bottom: 16px;
        border-bottom: 1px dashed var(--amber-deep);
