      @media (max-width: 720px) {
        .order-card {
          grid-template-columns: 1fr;
          gap: 24px;
          padding: 28px 22px;
        }
      }
      .order-seal {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
      }
      .order-seal .ring {
        width: 180px;
        height: 180px;
        border: 4px double var(--blue-stamp);
        border-radius: 50%;
        display: flex;
        align-items: center;
