        line-height: 1;
        color: var(--ink);
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .kept-banner .label {
        font-family: var(--stamp);
        font-size: 11px;
        color: var(--amber-deep);
        text-transform: uppercase;
        letter-spacing: 0.2em;
      }
      .kept-list {
