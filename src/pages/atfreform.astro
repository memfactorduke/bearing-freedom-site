      .kept-item p {
        font-family: var(--body);
        font-size: 16px;
        color: var(--ink-soft);
        line-height: 1.55;
      }

      /* ═════════════════════════════════════════ */
      /* ORDER CARD — 5370.1H                       */
      /* ═════════════════════════════════════════ */
      .order-card {
        position: relative;
        background: var(--paper-shade);
        border: 2px solid var(--ink);
        padding: 40px;
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 40px;
        align-items: center;
      }
      .order-card::before {
        content: '';
        position: absolute;
        inset: 6px;
        border: 1px solid var(--ink-mid);
        pointer-events: none;
