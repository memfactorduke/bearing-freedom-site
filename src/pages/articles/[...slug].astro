---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import MetadataSidebar from '../../components/MetadataSidebar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

const formattedDate = new Date(data.date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={data.title} description={data.title} image={data.thumbnail}>
  <!-- Article header band -->
  <div class="bg-surface border-b border-border">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10 md:py-14">
      <nav class="text-xs text-text-muted mb-5 flex items-center gap-2 animate-fade-in font-[JetBrains_Mono]">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <svg class="w-3 h-3 text-text-muted/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-text-secondary truncate max-w-xs">{data.title}</span>
      </nav>

      <div class="animate-fade-up">
        <div class="flex flex-wrap gap-2 mb-4">
          {data.content_type.map(type => (
            <span class="tag-chip">
              {type.replace(/-/g, ' ')}
            </span>
          ))}
        </div>

        <h1 class="font-[Syne] text-2xl sm:text-3xl md:text-4xl font-bold text-text leading-tight tracking-tight mb-5 max-w-3xl">
          {data.title}
        </h1>

        <div class="flex items-center gap-3 font-[JetBrains_Mono] text-xs text-text-muted">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-accent flex items-center justify-center shrink-0">
              <span class="text-[10px] text-white font-bold">{data.author.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase()}</span>
            </div>
            <span class="text-text-secondary font-medium">{data.author}</span>
          </div>
          <span class="w-1 h-1 rounded-full bg-border"></span>
          <time>{formattedDate}</time>
          <span class="w-1 h-1 rounded-full bg-border"></span>
          <span>{data.duration}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-10">
      <!-- Article Content -->
      <article data-pagefind-body class="animate-fade-up stagger-1">
        <VideoEmbed youtube_id={data.youtube_id} title={data.title} />

        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Article footer: email capture -->
        <div class="mt-14 pt-10 border-t border-border">
          <div class="bg-surface rounded-xl p-8 md:p-10 border border-border">
            <div class="max-w-md">
              <h3 class="font-[Syne] text-xl font-bold text-text mb-2">Get the Weekly Briefing</h3>
              <p class="text-sm text-text-secondary leading-relaxed mb-5 font-[Crimson_Pro]">
                New analysis delivered every week. Court decisions, case updates, and expert commentary.
              </p>
              <form id="article-email-form" name="newsletter-article" method="POST" data-netlify="true" class="flex gap-2">
                <input type="hidden" name="form-name" value="newsletter-article" />
                <input
                  type="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                  class="flex-1 bg-surface-raised border border-border rounded-lg px-4 py-2.5 text-sm text-text placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition-all font-[JetBrains_Mono]"
                />
                <button
                  type="submit"
                  class="bg-accent text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-accent/90 transition-colors whitespace-nowrap font-[Syne]"
                >
                  Subscribe
                </button>
              </form>
              <div id="article-email-success" class="hidden mt-4 text-sm text-accent font-medium flex items-center gap-2 font-[JetBrains_Mono]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                You're subscribed!
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <div class="animate-slide-right stagger-2 lg:sticky lg:top-24 lg:self-start">
        <MetadataSidebar
          topics={data.topics}
          states={data.states}
          content_type={data.content_type}
          tags={data.tags}
          youtube_url={data.youtube_url}
          date={data.date}
          duration={data.duration}
        />
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('article-email-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const success = document.getElementById('article-email-success');
      const btn = this.querySelector('button');
      btn.textContent = 'Subscribing...';
      btn.disabled = true;
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(this)).toString(),
        });
        this.style.display = 'none';
        success.classList.remove('hidden');
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  </script>
</BaseLayout>
