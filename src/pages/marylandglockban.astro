---
// Standalone page — self-contained styles and scripts, no global.css
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maryland Glock Ban (SB 334) | Bearing Freedom</title>
    <meta
      name="description"
      content="Maryland SB 334 bans Glocks and cruciform trigger bar pistols. Full breakdown of what's banned, who's affected, penalties, and legal challenges."
    />
    <meta
      property="og:title"
      content="Maryland Glock Ban (SB 334) | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="Maryland bans Glocks by targeting the cruciform trigger bar. Full breakdown of SB 334 — what's banned, timeline, penalties, and the Bruen problem."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://bearingfreedom.com/marylandglockban"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YJWJPMSXN4"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-YJWJPMSXN4');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg: #05080e;
        --surface: #0a1020;
        --raised: #0f1630;
        --accent: #3b7dd8;
        --accent-bright: #5a9fe8;
        --accent-glow: rgba(59, 125, 216, 0.15);
        --accent-line: rgba(59, 125, 216, 0.3);
        --danger: #c23b3b;
        --danger-dim: rgba(194, 59, 59, 0.08);
        --safe: #2d9e5f;
        --safe-dim: rgba(45, 158, 95, 0.06);
        --caution: #c9922a;
        --caution-dim: rgba(201, 146, 42, 0.06);
        --text: #d0d5e2;
        --text-bright: #ebeef5;
        --text-dim: #7a8399;
        --text-muted: #4a5268;
        --border: #1a2040;
        --border-light: #243060;
        --display: 'Bebas Neue', sans-serif;
        --serif: 'Cormorant Garamond', Georgia, serif;
        --mono: 'Space Mono', monospace;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--serif);
        font-size: 17px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      /* Grain overlay */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
      }

      a {
        color: var(--accent-bright);
        text-decoration: none;
      }
      a:hover {
        color: #8ac0ff;
      }

      /* ════════════════════════ NAV ════════════════════════ */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(5, 8, 14, 0.85);
        backdrop-filter: blur(20px) saturate(1.4);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
        padding: 0 28px;
      }
      .nav-brand {
        font-family: var(--display);
        font-size: 26px;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: 2px;
      }
      .nav-links {
        display: flex;
        gap: 24px;
      }
      .nav-links a {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-dim);
      }
      .nav-links a:hover {
        color: var(--text-bright);
      }

      /* ════════════════════════ TICKER ════════════════════════ */
      .ticker {
        background: linear-gradient(
          90deg,
          #1a0808 0%,
          var(--danger) 15%,
          var(--danger) 85%,
          #1a0808 100%
        );
        overflow: hidden;
        white-space: nowrap;
        padding: 7px 0;
        border-bottom: 1px solid rgba(194, 59, 59, 0.3);
      }
      .ticker-inner {
        display: inline-block;
        animation: tickerScroll 50s linear infinite;
      }
      .ticker-inner span {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.92);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .ticker-dot {
        display: inline-block;
        width: 4px;
        height: 4px;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 50%;
        margin: 0 20px;
        vertical-align: middle;
      }
      @keyframes tickerScroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }

      /* ════════════════════════ HERO ════════════════════════ */
      .hero {
        position: relative;
        padding: 100px 28px 80px;
        overflow: hidden;
        background:
          radial-gradient(
            ellipse 80% 50% at 20% 40%,
            rgba(59, 125, 216, 0.06) 0%,
            transparent 70%
          ),
          radial-gradient(
            ellipse 60% 40% at 80% 60%,
            rgba(194, 59, 59, 0.04) 0%,
            transparent 60%
          );
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(59, 125, 216, 0.015) 2px,
          rgba(59, 125, 216, 0.015) 3px
        );
        pointer-events: none;
      }
      .hero-inner {
        max-width: 1100px;
        margin: 0 auto;
        position: relative;
      }
      .hero-eyebrow {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.25em;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .hero-eyebrow::before {
        content: '';
        width: 40px;
        height: 1px;
        background: var(--accent);
      }
      .hero-pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--caution);
        box-shadow:
          0 0 8px var(--caution),
          0 0 16px rgba(201, 146, 42, 0.3);
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.4;
        }
      }

      .hero h1 {
        font-family: var(--display);
        font-size: clamp(56px, 10vw, 120px);
        line-height: 0.92;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-bright);
        margin-bottom: 8px;
      }
      .hero h1 em {
        font-style: normal;
        color: var(--danger);
        display: block;
      }
      .hero-sub {
        font-family: var(--serif);
        font-size: 20px;
        font-weight: 400;
        color: var(--text);
        max-width: 600px;
        line-height: 1.7;
        margin-top: 24px;
      }
      .hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 32px;
      }
      .chip {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 2px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1px solid var(--border);
        color: var(--text-dim);
        background: var(--surface);
      }
      .chip-danger {
        border-color: var(--danger);
        color: var(--danger);
      }
      .chip-caution {
        border-color: var(--caution);
        color: var(--caution);
      }

      /* ════════════════════════ STATS BAR ════════════════════════ */
      .stats-bar {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        border: 1px solid var(--border);
        border-top: 2px solid var(--accent);
        background: var(--surface);
      }
      .stat-cell {
        padding: 24px 16px;
        text-align: center;
        border-right: 1px solid var(--border);
        position: relative;
      }
      .stat-cell:last-child {
        border-right: none;
      }
      .stat-num {
        font-family: var(--display);
        font-size: 32px;
        color: var(--text-bright);
        letter-spacing: 1px;
      }
      .stat-num.danger {
        color: var(--danger);
      }
      .stat-num.caution {
        color: var(--caution);
      }
      .stat-lbl {
        font-family: var(--mono);
        font-size: 8px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-top: 6px;
      }

      /* ════════════════════════ CONTENT ════════════════════════ */
      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 28px;
      }

      .sect {
        padding: 72px 0;
        position: relative;
      }
      .sect + .sect {
        border-top: 1px solid var(--border);
      }

      /* Section headers */
      .sect-head {
        margin-bottom: 36px;
        display: flex;
        align-items: flex-end;
        gap: 20px;
      }
      .sect-num {
        font-family: var(--display);
        font-size: 64px;
        line-height: 0.8;
        color: var(--border-light);
        letter-spacing: 2px;
      }
      .sect-title {
        font-family: var(--display);
        font-size: 36px;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-bright);
        line-height: 1;
      }

      .body-text {
        font-family: var(--serif);
        font-size: 18px;
        color: var(--text);
        line-height: 1.8;
        max-width: 720px;
        margin-bottom: 20px;
      }
      .body-text strong {
        color: var(--text-bright);
        font-weight: 600;
      }

      /* Callout blocks */
      .alert {
        position: relative;
        border: 1px solid var(--border);
        padding: 28px 28px 28px 32px;
        margin: 28px 0;
        background: var(--surface);
        overflow: hidden;
      }
      .alert::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--accent);
      }
      .alert-danger::before {
        background: var(--danger);
      }
      .alert-caution::before {
        background: var(--caution);
      }
      .alert-safe::before {
        background: var(--safe);
      }

      .alert-tag {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .alert-danger .alert-tag {
        color: var(--danger);
      }
      .alert-caution .alert-tag {
        color: var(--caution);
      }
      .alert-safe .alert-tag {
        color: var(--safe);
      }

      .alert p {
        font-family: var(--serif);
        font-size: 15px;
        color: var(--text);
        line-height: 1.7;
        margin: 0;
      }
      .alert p strong {
        color: var(--text-bright);
      }
      .alert p em {
        color: var(--accent-bright);
        font-style: italic;
      }

      /* ════════════════════════ TABLES ════════════════════════ */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-family: var(--serif);
        border: 1px solid var(--border);
      }
      .data-table thead th {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 12px 18px;
        text-align: left;
        background: var(--raised);
        color: var(--text-dim);
        border-bottom: 2px solid var(--accent-line);
      }
      .data-table tbody td {
        padding: 14px 18px;
        font-size: 15px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        vertical-align: top;
      }
      .data-table tbody tr {
        transition: background 0.15s;
      }
      .data-table tbody tr:hover {
        background: rgba(59, 125, 216, 0.03);
      }
      .data-table td strong {
        color: var(--text-bright);
        font-weight: 600;
      }

      .badge {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 3px 10px;
        border-radius: 2px;
        display: inline-block;
      }
      .badge-ban {
        background: var(--danger-dim);
        color: var(--danger);
        border: 1px solid rgba(194, 59, 59, 0.2);
      }
      .badge-ok {
        background: var(--safe-dim);
        color: var(--safe);
        border: 1px solid rgba(45, 158, 95, 0.2);
      }
      .badge-tbd {
        background: var(--caution-dim);
        color: var(--caution);
        border: 1px solid rgba(201, 146, 42, 0.2);
      }

      /* ════════════════════════ FEATURE LIST ════════════════════════ */
      .flist {
        margin: 24px 0;
      }
      .flist-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
        font-size: 15px;
        color: var(--text);
      }
      .flist-dot {
        flex-shrink: 0;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        margin-top: 9px;
      }
      .flist-row strong {
        color: var(--text-bright);
        font-weight: 600;
      }

      /* ════════════════════════ TIMELINE ════════════════════════ */
      .timeline {
        position: relative;
        margin: 32px 0;
        padding-left: 32px;
      }
      .timeline::before {
        content: '';
        position: absolute;
        left: 7px;
        top: 8px;
        bottom: 8px;
        width: 1px;
        background: linear-gradient(180deg, var(--accent), var(--border) 80%);
      }
      .tl-entry {
        position: relative;
        padding: 14px 0 14px 24px;
        font-size: 15px;
      }
      .tl-entry::before {
        content: '';
        position: absolute;
        left: -28px;
        top: 20px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--border-light);
        border: 2px solid var(--bg);
      }
      .tl-entry.major::before {
        background: var(--accent);
        box-shadow: 0 0 6px var(--accent);
      }
      .tl-date {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        color: var(--text-dim);
        letter-spacing: 0.06em;
      }
      .tl-desc {
        color: var(--text);
        margin-top: 2px;
      }
      .tl-entry.major .tl-desc {
        color: var(--text-bright);
        font-weight: 600;
      }

      /* ════════════════════════ DOSSIER DIVIDER ════════════════════════ */
      .divider {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 48px 0 0;
      }
      .divider-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--accent-line), transparent);
      }
      .divider-line:last-child {
        background: linear-gradient(90deg, transparent, var(--accent-line));
      }
      .divider-label {
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--text-muted);
      }

      /* ════════════════════════ VIDEO ════════════════════════ */
      .video-wrap {
        position: relative;
        padding-bottom: 56.25%;
        margin: 32px 0;
        border: 1px solid var(--border);
        background: var(--surface);
        overflow: hidden;
      }
      .video-wrap iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }

      /* ════════════════════════ CTA ════════════════════════ */
      .cta-block {
        text-align: center;
        padding: 80px 28px;
        background: radial-gradient(
          ellipse at center,
          var(--accent-glow) 0%,
          transparent 60%
        );
      }
      .cta-text {
        font-family: var(--display);
        font-size: 28px;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--text-dim);
        margin-bottom: 24px;
      }
      .cta-btn {
        display: inline-block;
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 700;
        padding: 14px 36px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: transparent;
        color: var(--accent-bright);
        border: 1px solid var(--accent);
        text-decoration: none;
        transition: all 0.3s;
      }
      .cta-btn:hover {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 0 20px var(--accent-glow);
      }

      /* ════════════════════════ FOOTER ════════════════════════ */
      .foot {
        border-top: 1px solid var(--border);
        padding: 28px;
        text-align: center;
      }
      .foot p {
        font-family: var(--mono);
        font-size: 9px;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        margin: 0;
      }

      /* ════════════════════════ SCROLL ANIMATIONS ════════════════════════ */
      [data-reveal] {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      [data-reveal].visible {
        opacity: 1;
        transform: translateY(0);
      }
      [data-reveal='delay-1'] {
        transition-delay: 0.1s;
      }
      [data-reveal='delay-2'] {
        transition-delay: 0.2s;
      }
      [data-reveal='delay-3'] {
        transition-delay: 0.3s;
      }
      [data-reveal='delay-4'] {
        transition-delay: 0.4s;
      }

      /* ════════════════════════ RESPONSIVE ════════════════════════ */
      @media (max-width: 768px) {
        .hero {
          padding: 60px 20px 50px;
        }
        .hero h1 {
          font-size: clamp(44px, 12vw, 80px);
        }
        .stats-bar {
          grid-template-columns: repeat(3, 1fr);
        }
        .nav-links {
          display: none;
        }
        .sect {
          padding: 48px 0;
        }
        .sect-head {
          flex-direction: column;
          gap: 4px;
          align-items: flex-start;
        }
        .sect-num {
          font-size: 36px;
        }
        .sect-title {
          font-size: 26px;
        }
        .wrap {
          padding: 0 20px;
        }
        .data-table {
          font-size: 13px;
        }
        .data-table thead th,
        .data-table tbody td {
          padding: 10px 12px;
        }
      }
      @media (max-width: 480px) {
        .stats-bar {
          grid-template-columns: repeat(2, 1fr);
        }
        .hero h1 {
          font-size: 44px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Nav -->
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">BF</a>
        <div class="nav-links">
          <a href="/">Articles</a>
          <a href="/extras">Extras</a>
          <a href="/legislation">VA Tracker</a>
          <a
            href="https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw"
            target="_blank"
            rel="noopener">YouTube</a
          >
        </div>
      </div>
    </nav>

    <!-- Ticker -->
    <div class="ticker">
      <div class="ticker-inner">
        <span>SB 334 passes Maryland legislature 92-39</span><span
          class="ticker-dot"></span>
        <span>Bans sale of Glocks and all cruciform trigger bar pistols</span
        ><span class="ticker-dot"></span>
        <span>On Governor Moore's desk</span><span class="ticker-dot"></span>
        <span>Maryland Shall Issue pledges lawsuit</span><span
          class="ticker-dot"></span>
        <span>Existing owners may keep firearms</span><span class="ticker-dot"
        ></span>
        <span>Sales ban begins Jan 1, 2027</span><span class="ticker-dot"
        ></span>
        <span
          >California's identical law (AB 1127) already challenged in Jaymes v.
          Bonta</span
        ><span class="ticker-dot"></span>
        <span>SB 334 passes Maryland legislature 92-39</span><span
          class="ticker-dot"></span>
        <span>Bans sale of Glocks and all cruciform trigger bar pistols</span
        ><span class="ticker-dot"></span>
        <span>On Governor Moore's desk</span><span class="ticker-dot"></span>
        <span>Maryland Shall Issue pledges lawsuit</span><span
          class="ticker-dot"></span>
        <span>Existing owners may keep firearms</span><span class="ticker-dot"
        ></span>
        <span>Sales ban begins Jan 1, 2027</span><span class="ticker-dot"
        ></span>
        <span
          >California's identical law (AB 1127) already challenged in Jaymes v.
          Bonta</span
        ><span class="ticker-dot"></span>
      </div>
    </div>

    <!-- Hero -->
