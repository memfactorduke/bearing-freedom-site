    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --void: #06080f;
        --bg: #0b1020;
        --court: #131a30;
        --court-2: #1a2240;
        --panel: #161e3a;
        --border: #2a3252;
        --border-dim: #1c2340;
        --grid: rgba(212, 168, 42, 0.06);

        --text: #f1ecdc;
        --text-mid: #c4bfac;
        --text-dim: #807c6c;
        --text-faint: #4f4d44;

        --gold: #d4a82a;
        --gold-deep: #8a6a18;
        --gold-glow: rgba(212, 168, 42, 0.18);

        --strike: #b22a36;
        --strike-deep: #7a1923;
        --strike-glow: rgba(178, 42, 54, 0.22);

        --uphold: #455a82;
        --uphold-deep: #2c3a55;
        --uphold-glow: rgba(69, 90, 130, 0.18);

        --bone: #ece1c4;
        --bone-deep: #c9bd9d;

