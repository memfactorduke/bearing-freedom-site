const grounds = [
  {
    n: '01',
    title: 'Special-session scope',
    status: 'Carried in part',
    blurb:
      'The 2024 special session was convened for a budget dispute and never formally adjourned. Democrats reopened it more than a year later for a redistricting amendment nobody contemplated when the session was originally called. Constitutional limits on special sessions exist precisely to prevent that bait-and-switch.',
    ruling:
      'Sustained as part of the broader Article XII, Section 1 holding. The court treated the procedural failure as a single integrated violation rather than a stand-alone basis.',
  },
  {
    n: '02',
    title: 'Intervening-election timing',
    status: 'Controlling',
    blurb:
      'The Virginia Constitution requires "an election" between the two General Assembly passages. Early voting for the November 4, 2025 election began September 19 — six weeks before the October 31 first passage. More than a million Virginians cast ballots in the supposed intervening election before the General Assembly took the first vote that election was supposed to provide a check on.',
    ruling:
      "The textualist hook with the most ideological gravity. Kelsey's majority called the way Democrats submitted the amendment 'unprecedented' — and the constitutional violation 'incurably taints the resulting referendum vote and nullifies its legal efficacy.'",
  },
  {
    n: '03',
    title: '90-day cooling-off period',
    status: 'Controlling',
    blurb:
      'Article XII, Section 1 requires a proposed amendment to sit at least ninety days between final passage and the referendum. Final passage was January 19, 2026. Early voting opened March 6, 2026. Forty-six days. Barely half the constitutional minimum.',
    ruling:
      "The cleanest math in the case. Code § 30-19.9 also requires 90 days of public posting at every circuit clerk's office — a guardrail Democrats tried to repeal with SB 769 mid-litigation. The House let the bill die. The requirement remained on the books, unmet.",
  },
  {
    n: '04',
    title: 'Misleading ballot title',
    status: 'Not reached',
    blurb:
      "The ballot question asked whether the Constitution should be amended to 'restore fairness' — language Judge Hurley found 'flagrantly misleading' on February 19. The RNC carried this argument as a parallel petition.",
    ruling:
      'The court did not need to reach this ground. The Article XII, Section 1 violations were dispositive. The misleading-language theory remains unresolved on the merits — but academically interesting only.',
  },
];

