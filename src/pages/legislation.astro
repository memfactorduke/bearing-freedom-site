---
// Standalone page — self-contained styles and scripts, no global.css
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Virginia Legislation Tracker | Bearing Freedom</title>
    <meta
      name="description"
      content="Track all 18 gun control bills on Governor Spanberger's desk. Assault weapons ban, red flag expansion, ghost gun ban, and more."
    />
    <meta
      property="og:title"
      content="Virginia Legislation Tracker | Bearing Freedom"
    />
    <meta
      property="og:description"
      content="The largest attack on the Second Amendment in Virginia history. Track every bill, know your rights."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bearingfreedom.com/legislation" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YJWJPMSXN4"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-YJWJPMSXN4');
    </script>
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      :root {
        --bg: #0c0c0c;
        --panel: #141414;
        --card: #1a1a1a;
        --card-hover: #1e1e1e;
        --card-active: #1f1518;
        --red: #dc2626;
        --red-glow: rgba(220, 38, 38, 0.15);
        --red-dim: #991b1b;
        --yellow: #eab308;
        --yellow-dim: #a16207;
        --amber: #f59e0b;
        --green: #22c55e;
        --green-dim: rgba(34, 197, 94, 0.1);
        --blue: #3b82f6;
        --blue-dim: rgba(59, 130, 246, 0.08);
        --purple: #a855f7;
        --white: #f0f0f0;
        --light: #d4d4d4;
        --dim: #a3a3a3;
        --muted: #525252;
        --faint: #303030;
        --border: #262626;
        --font: 'Inter', sans-serif;
        --mono: 'JetBrains Mono', monospace;
        --head: 'Oswald', sans-serif;
        --radius: 8px;
      }
      body {
        background: var(--bg);
        color: var(--white);
        font-family: var(--font);
        overflow: hidden;
        height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      /* ═══════ LAYOUT ═══════ */
      .app {
        display: grid;
        grid-template-columns: 370px 1fr;
        grid-template-rows: auto auto 1fr;
        height: 100vh;
      }

      /* ── Breaking ticker ── */
      .breaking-bar {
        grid-column: 1/-1;
        background: var(--red);
        display: flex;
        align-items: center;
        height: 34px;
        overflow: hidden;
      }
      .breaking-label {
        background: var(--yellow);
        color: #000;
        font-family: var(--head);
        font-size: 13px;
        font-weight: 700;
        padding: 0 18px;
        height: 100%;
        display: flex;
        align-items: center;
        letter-spacing: 2px;
        text-transform: uppercase;
        flex-shrink: 0;
      }
      .ticker {
        flex: 1;
        overflow: hidden;
        height: 100%;
        display: flex;
        align-items: center;
      }
      .ticker-text {
        white-space: nowrap;
        font-family: var(--font);
        font-size: 12.5px;
        font-weight: 600;
        color: #fff;
        animation: tickerScroll 45s linear infinite;
        padding-left: 100%;
      }
      @keyframes tickerScroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-100%);
        }
      }

      /* ── Top bar ── */
      .topbar {
        grid-column: 1/-1;
        background: var(--panel);
        border-bottom: 2px solid var(--yellow);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        height: 54px;
      }
      .topbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .live-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--red);
        animation: pulse 1.5s infinite;
        box-shadow: 0 0 10px rgba(220, 38, 38, 0.5);
      }
      .topbar-brand {
        font-family: var(--head);
        font-size: 21px;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--white);
      }
      .cd-box {
        background: var(--red);
        padding: 5px 16px;
        border-radius: 4px;
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
      }
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .filter-pills {
        display: flex;
        gap: 4px;
      }
      .pill {
        font-size: 10px;
        font-weight: 700;
        padding: 5px 11px;
        border-radius: 4px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.15s;
        font-family: var(--head);
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .pill:hover {
        border-color: var(--yellow);
        color: var(--yellow);
      }
      .pill.active {
        background: var(--yellow);
        border-color: var(--yellow);
        color: #000;
      }
      .pill-signed {
        border-color: #16a34a;
        color: #16a34a;
      }
      .pill-signed:hover {
        border-color: #22c55e;
        color: #22c55e;
      }
      .pill-signed.active {
        background: #16a34a;
        border-color: #16a34a;
        color: #fff;
      }
      .pill-unsigned {
        border-color: #eab308;
        color: #eab308;
      }
      .pill-unsigned:hover {
        border-color: #facc15;
        color: #facc15;
      }
      .pill-unsigned.active {
        background: #eab308;
        border-color: #eab308;
        color: #000;
      }
      .pill-govrec {
        border-color: #a855f7;
        color: #a855f7;
      }
      .pill-govrec:hover {
        border-color: #c084fc;
        color: #c084fc;
      }
      .pill-govrec.active {
        background: #a855f7;
        border-color: #a855f7;
        color: #fff;
      }
      .govrec-badge {
        position: absolute;
        top: 0;
        right: 0;
        background: #a855f7;
        color: #fff;
        font-family: var(--mono);
        font-size: 7px;
        font-weight: 700;
        letter-spacing: 1.5px;
        padding: 2px 6px;
        border-radius: 0 0 0 4px;
        text-transform: uppercase;
      }
      .bill-item.is-govrec .bill-item-cat {
        background: #a855f7 !important;
        color: #fff !important;
      }
      .detail-govrec {
        display: inline-block;
        background: #a855f7;
        color: #fff;
        font-family: var(--head);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 4px 14px;
        border-radius: 4px;
      }
      .new-badge {
        display: inline-block;
        background: #ef4444;
        color: #fff;
        font-family: var(--mono);
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 1px;
        padding: 2px 5px;
        border-radius: 3px;
        margin-left: 6px;
        vertical-align: middle;
        animation: pulse-new 1.5s ease-in-out infinite;
      }
      @keyframes pulse-new {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.6;
        }
      }
      .changes-section {
        margin: 0 0 32px 0;
        padding: 24px;
        background: linear-gradient(
          135deg,
          rgba(168, 85, 247, 0.12),
          rgba(168, 85, 247, 0.04)
        );
        border: 2px solid rgba(168, 85, 247, 0.4);
        border-radius: var(--radius);
        position: relative;
      }
      .changes-section::before {
        content: '📝 WHAT THE GOVERNOR CHANGED';
        display: block;
        font-family: var(--head);
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 3px;
        color: #a855f7;
        margin-bottom: 8px;
      }
      .changes-section h3 {
        font-family: var(--head);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #c084fc;
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(168, 85, 247, 0.2);
      }
      .changes-section .change-item {
        margin-bottom: 16px;
        padding: 14px 16px;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 8px;
        border-left: 4px solid #a855f7;
      }
      .changes-section .change-label {
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
      }
      .changes-section .change-label.removed {
        color: #ef4444;
      }
      .changes-section .change-label.added {
        color: #22c55e;
      }
      .changes-section .change-label.modified {
        color: #eab308;
      }
      .changes-section .change-label.pending {
        color: #a855f7;
      }
      .changes-section .change-old {
        color: var(--dim);
        font-size: 12.5px;
        text-decoration: line-through;
        margin-bottom: 6px;
        line-height: 1.5;
      }
      .changes-section .change-new {
        color: var(--white);
        font-size: 12.5px;
        line-height: 1.5;
      }
      .changes-section .change-note {
        color: var(--dim);
        font-size: 11px;
        font-style: italic;
        margin-top: 6px;
      }
      .changes-section .co {
        margin-top: 16px;
      }
      .signed-badge {
        position: absolute;
        top: 0;
        right: 0;
        background: #16a34a;
        color: #fff;
        font-family: var(--mono);
        font-size: 7px;
        font-weight: 700;
        letter-spacing: 1.5px;
        padding: 2px 6px;
        border-radius: 0 0 0 4px;
        text-transform: uppercase;
      }
      .bill-item.is-signed .bill-item-cat {
        background: #16a34a !important;
        color: #fff !important;
      }
      .detail-signed {
        display: inline-block;
        background: #16a34a;
        color: #fff;
        font-family: var(--head);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 4px 14px;
        border-radius: 4px;
        text-transform: uppercase;
      }
      .dot-green {
        background: #16a34a;
      }
      .sub-btn {
        background: var(--red);
        color: #fff;
        border: none;
        padding: 7px 16px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 11px;
        cursor: pointer;
        font-family: var(--head);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.15s;
      }
      .sub-btn:hover {
        background: #b91c1c;
      }

      /* ═══════ SIDEBAR ═══════ */
      .sidebar {
        background: var(--panel);
        border-right: 1.5px solid var(--border);
        overflow-y: auto;
        padding: 0;
      }
      .sidebar::-webkit-scrollbar {
        width: 3px;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: var(--red);
        border-radius: 3px;
      }

      .sidebar-header {
        font-family: var(--head);
        font-size: 13px;
        letter-spacing: 2.5px;
        color: var(--yellow);
        padding: 16px 20px;
        border-bottom: 1.5px solid var(--border);
        text-transform: uppercase;
        background: linear-gradient(
          90deg,
          rgba(234, 179, 8, 0.04),
          transparent
        );
      }

      .bill-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        cursor: pointer;
        transition: all 0.12s;
        border-bottom: 1px solid var(--border);
        border-left: 3px solid transparent;
      }
      .bill-item:hover {
        background: rgba(220, 38, 38, 0.03);
        border-left-color: var(--yellow);
      }
      .bill-item.active {
        background: var(--card-active);
        border-left-color: var(--red);
        box-shadow: inset 0 0 50px rgba(220, 38, 38, 0.05);
      }

      .bill-item-num-wrap {
        min-width: 42px;
        height: 42px;
        border-radius: 6px;
        background: var(--red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--head);
        font-size: 18px;
        color: #fff;
        font-weight: 700;
        flex-shrink: 0;
      }
      .bill-item-text {
        flex: 1;
        min-width: 0;
      }
      .bill-item-title {
        font-family: var(--head);
        font-size: 14px;
        font-weight: 600;
        line-height: 1.35;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--white);
      }
      .bill-item-id {
        font-family: var(--mono);
        font-size: 10.5px;
        color: var(--muted);
        margin-top: 4px;
        letter-spacing: 0.3px;
      }
      .bill-item-cat {
        font-family: var(--head);
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        padding: 4px 10px;
        border-radius: 4px;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .cat-ban {
        color: #fff;
        background: var(--red);
      }
      .cat-seize {
        color: #000;
        background: var(--yellow);
      }
      .cat-zone {
        color: #fff;
        background: var(--blue);
      }
      .cat-carry {
        color: #fff;
        background: var(--green);
      }
      .cat-prog {
        color: #fff;
        background: var(--purple);
      }

      /* ═══════ MAIN PANEL ═══════ */
      .main {
        overflow-y: auto;
        padding: 44px 56px 100px;
        background: var(--bg);
      }
      .main::-webkit-scrollbar {
        width: 3px;
      }
      .main::-webkit-scrollbar-thumb {
        background: var(--red);
        border-radius: 3px;
      }

      /* ── Header ── */
      .detail-header {
        margin-bottom: 28px;
      }
      .detail-live {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--red);
        padding: 5px 14px;
        border-radius: 4px;
        font-family: var(--head);
        font-size: 10.5px;
        color: #fff;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 14px;
      }
      .detail-live .blink {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fff;
        animation: pulse 1s infinite;
      }
      .detail-bill-id {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--yellow);
        display: block;
        margin-bottom: 10px;
        font-weight: 500;
        letter-spacing: 0.5px;
      }
      .detail-title {
        font-family: var(--head);
        font-size: clamp(32px, 3.5vw, 54px);
        font-weight: 700;
        line-height: 1.08;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 18px;
        background: linear-gradient(180deg, #fff 40%, #999);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .detail-meta {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
      }
      .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11.5px;
        color: var(--dim);
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 5px 12px;
        font-weight: 500;
      }
      .meta-chip .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .meta-chip .dot-red {
        background: var(--red);
        box-shadow: 0 0 6px rgba(220, 38, 38, 0.4);
      }
      .meta-chip .dot-yellow {
        background: var(--yellow);
      }
      .meta-chip .dot-gray {
        background: var(--muted);
      }

      .divider {
        height: 2px;
        background: linear-gradient(90deg, var(--red), transparent);
        margin: 24px 0 32px;
        position: relative;
      }
      .divider::after {
        content: attr(data-label);
        position: absolute;
        top: -8px;
        left: 0;
        background: var(--bg);
        padding-right: 14px;
        font-family: var(--head);
        font-size: 10px;
        color: var(--red);
        letter-spacing: 2.5px;
        text-transform: uppercase;
      }

      /* ═══════ RICH CONTENT SYSTEM ═══════ */
      .bill-body {
        max-width: 840px;
      }
      .bill-body p {
        font-size: 15px;
        color: var(--light);
        line-height: 1.9;
        margin-bottom: 22px;
        font-weight: 400;
      }
      .bill-body strong {
        color: #fff;
        font-weight: 700;
      }
      .bill-body em {
        color: var(--dim);
        font-style: italic;
      }

      /* Section headers — major topic breaks */
      .sh {
        font-family: var(--head);
        font-size: 20px;
        font-weight: 600;
        letter-spacing: 1.5px;
        color: var(--white);
        text-transform: uppercase;
        margin: 52px 0 20px;
        padding: 14px 0 12px;
        border-top: 1px solid var(--faint);
        border-bottom: 1.5px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .sh::before {
        content: '';
        width: 5px;
        height: 24px;
        border-radius: 2px;
        background: var(--red);
        flex-shrink: 0;
      }
      .sh:first-child {
        margin-top: 0;
        border-top: none;
      }

      /* Subsection label — minor headers within a section */
      .ssl {
        font-family: var(--head);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--yellow);
        text-transform: uppercase;
        margin: 32px 0 8px;
        padding-left: 17px;
        border-left: 3px solid var(--yellow);
      }

      /* Callout boxes */
      .co {
        border-radius: var(--radius);
        padding: 22px 24px;
        margin: 24px 0;
        border-left: 4px solid;
        font-size: 14px;
        line-height: 1.8;
        color: var(--light);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
      }
      .co-red {
        background: rgba(220, 38, 38, 0.07);
        border-color: var(--red);
      }
      .co-green {
        background: rgba(34, 197, 94, 0.06);
        border-color: var(--green);
      }
      .co-yellow {
        background: rgba(234, 179, 8, 0.06);
        border-color: var(--yellow);
      }
      .co-blue {
        background: rgba(59, 130, 246, 0.06);
        border-color: var(--blue);
      }
      .co-t {
        font-family: var(--head);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 10px;
      }
      .co-red .co-t {
        color: var(--red);
      }
      .co-green .co-t {
        color: var(--green);
      }
      .co-yellow .co-t {
        color: var(--yellow);
      }
      .co-blue .co-t {
        color: var(--blue);
      }
      .co strong {
        color: #fff;
      }

      /* Formula boxes */
      .fx {
        background: var(--card);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 24px;
        margin: 22px 0;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
      }
      .fx-p {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--faint);
        border-radius: 5px;
        padding: 10px 16px;
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 500;
        color: var(--light);
      }
      .fx-op {
        color: var(--yellow);
        font-size: 20px;
        font-weight: 900;
        font-family: var(--mono);
      }
      .fx-r {
        background: rgba(220, 38, 38, 0.14);
        border: 2px solid var(--red);
        border-radius: 5px;
        padding: 10px 16px;
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 700;
        color: var(--red);
      }

      /* Tables */
      .tb {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 22px 0;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1.5px solid var(--border);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
      }
      .tb th {
        font-family: var(--head);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--dim);
        text-align: left;
        padding: 14px 18px;
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1.5px solid var(--border);
      }
      .tb td {
        padding: 12px 18px;
        border-bottom: 1px solid var(--border);
        color: var(--light);
        font-size: 13.5px;
        line-height: 1.55;
      }
      .tb tr:last-child td {
        border-bottom: none;
      }
      .tb tr:nth-child(even) td {
        background: rgba(255, 255, 255, 0.012);
      }
