---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Bearing Freedom.">
  <!-- Header band -->
  <div class="bg-surface border-b border-border">
    <div class="max-w-4xl mx-auto px-5 lg:px-8 pt-12 pb-16">
      <div class="text-xs text-accent font-[JetBrains_Mono] tracking-[0.2em] uppercase mb-2 animate-fade-up">Reach Out</div>
      <h1 class="font-[Syne] text-3xl font-bold text-text tracking-tight mb-3 animate-fade-up stagger-1">Get in touch</h1>
      <p class="text-text-secondary text-sm font-[Crimson_Pro] animate-fade-up stagger-2">Have a question, tip, or want to collaborate? Reach out below.</p>
    </div>
  </div>

  <!-- Contact Form -->
  <div class="max-w-2xl mx-auto px-5 lg:px-8 py-14">
    <form
      id="contact-form"
      name="contact"
      method="POST"
      data-netlify="true"
      class="space-y-6"
    >
      <input type="hidden" name="form-name" value="contact" />

      <div>
        <label for="contact-name" class="block text-sm font-[Syne] font-semibold text-text-secondary mb-1.5">Name</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          required
          class="w-full bg-surface-raised border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition-all font-[JetBrains_Mono]"
          placeholder="Your name"
        />
      </div>

      <div>
        <label for="contact-email" class="block text-sm font-[Syne] font-semibold text-text-secondary mb-1.5">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          required
          class="w-full bg-surface-raised border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition-all font-[JetBrains_Mono]"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="contact-subject" class="block text-sm font-[Syne] font-semibold text-text-secondary mb-1.5">Subject</label>
        <input
          type="text"
          id="contact-subject"
          name="subject"
          required
          class="w-full bg-surface-raised border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition-all font-[JetBrains_Mono]"
          placeholder="What is this about?"
        />
      </div>

      <div>
        <label for="contact-message" class="block text-sm font-[Syne] font-semibold text-text-secondary mb-1.5">Message</label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="6"
          class="w-full bg-surface-raised border border-border rounded-lg px-4 py-3 text-sm text-text placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/15 transition-all resize-none font-[Crimson_Pro] text-base leading-relaxed"
          placeholder="Your message..."
        ></textarea>
      </div>

      <button
        type="submit"
        id="contact-submit"
        class="bg-accent text-white px-8 py-3 rounded-lg text-sm font-[Syne] font-semibold hover:bg-accent/90 transition-colors active:scale-[0.98]"
      >
        Send Message
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="contact-success" class="hidden mt-8">
      <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-5 py-3 rounded-lg text-sm font-[JetBrains_Mono] font-medium border border-accent/20">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        Message sent. Thanks for reaching out!
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('contact-submit');
      const success = document.getElementById('contact-success');

      btn.textContent = 'Sending...';
      btn.disabled = true;

      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(this)).toString(),
        });
        this.style.display = 'none';
        success.classList.remove('hidden');
        success.classList.add('animate-fade-up');
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  </script>
</BaseLayout>
