---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => { const d = b.data.date.localeCompare(a.data.date); return d !== 0 ? d : (a.data.sort_index ?? 9999) - (b.data.sort_index ?? 9999); });

const featuredArticle = articles.find(a => a.data.youtube_id === 'QlhdoNOAvO0') || articles[0];
const remainingArticles = articles.filter(a => a !== featuredArticle);
const allTopics = [...new Set(articles.flatMap(a => a.data.topics))];
---

<BaseLayout title="Home" description="Second Amendment commentary and opinion — by Bearing Freedom.">

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Bearing Freedom",
      "url": "https://bearingfreedom.com",
      "logo": "https://bearingfreedom.com/favicon.svg",
      "sameAs": [
        "https://www.youtube.com/channel/UCmuwdcAbeBR16b8q6CBUsTw"
      ],
      "description": "Second Amendment commentary and analysis"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Bearing Freedom",
      "url": "https://bearingfreedom.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://bearingfreedom.com/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />
  </Fragment>

  <!-- ═══════════════════════════════════════════════
       HERO — Featured article, full-width, cinematic
  ═══════════════════════════════════════════════ -->
  <section class="bg-void border-b border-border">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-24">

      {featuredArticle ? (
        <a href={`/articles/${featuredArticle.id}`} class="group block">
          <div class="grid lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">

            <!-- Image column -->
            <div class="relative overflow-hidden bg-surface order-1 lg:order-2 mb-8 lg:mb-0">
              {featuredArticle.data.thumbnail && (
                <img
                  src={featuredArticle.data.thumbnail}
                  alt={featuredArticle.data.title}
                  class="w-full h-64 sm:h-80 lg:h-full object-cover opacity-75 group-hover:opacity-90 transition-opacity duration-500"
                />
              )}
              <!-- Gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-void/60 via-transparent to-transparent lg:bg-gradient-to-r lg:from-void/30 lg:via-transparent lg:to-transparent"></div>
              <!-- Featured badge -->
              <div class="absolute top-4 left-4">
                <span class="font-[JetBrains_Mono] text-[10px] tracking-[0.2em] uppercase bg-accent text-void px-2.5 py-1 font-bold">
                  Featured
                </span>
              </div>
              <!-- Duration badge -->
              {featuredArticle.data.duration && (
                <span class="absolute bottom-4 right-4 font-[JetBrains_Mono] text-[10px] tracking-wider text-text-secondary bg-void/80 px-2 py-1 backdrop-blur-sm">
                  {featuredArticle.data.duration}
                </span>
              )}
            </div>

            <!-- Text column -->
            <div class="order-2 lg:order-1 flex flex-col justify-center py-2 lg:py-8">

              <!-- Section label -->
              <div class="flex items-center gap-3 mb-6">
                <div class="w-6 h-px bg-accent"></div>
                <span class="font-[JetBrains_Mono] text-[10px] tracking-[0.25em] uppercase text-accent">
                  Featured
                </span>
              </div>

              <!-- Date -->
              <time class="font-[JetBrains_Mono] text-xs text-accent mb-4 block">
                {new Date(featuredArticle.data.date + 'T00:00:00').toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>

              <!-- Title -->
              <h1 class="font-[Archivo_Black] text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text leading-[1.05] tracking-tight mb-6 group-hover:text-accent transition-colors duration-300">
                {featuredArticle.data.title}
              </h1>

              <!-- Excerpt from topics as context signal -->
              {featuredArticle.data.topics?.length > 0 && (
                <p class="font-[Crimson_Pro] text-lg text-text-secondary leading-relaxed mb-8">
                  Commentary on {featuredArticle.data.topics.slice(0, 3).map(t => t.replace(/-/g, ' ')).join(', ')}.
                </p>
              )}

              <!-- CTA -->
              <div class="flex items-center gap-3 text-sm font-[Archivo_Black] font-semibold text-accent group-hover:gap-5 transition-all duration-300">
                <span>Read article</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </div>

              <!-- Topics -->
              {featuredArticle.data.topics?.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-border">
                  {featuredArticle.data.topics.slice(0, 4).map(topic => (
                    <span class="font-[JetBrains_Mono] text-[10px] tracking-wider uppercase text-text-muted border border-border px-2.5 py-1">
                      {topic.replace(/-/g, ' ')}
                    </span>
                  ))}
                </div>
              )}
            </div>

          </div>
        </a>
      ) : (
        <!-- Fallback if no articles -->
        <div class="text-center py-24">
          <h1 class="font-[Archivo_Black] text-5xl font-extrabold text-text mb-4">Bearing Freedom</h1>
          <p class="font-[Crimson_Pro] text-lg text-text-secondary">Second Amendment commentary and opinion.</p>
        </div>
      )}

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       INLINE EMAIL BAR — High-visibility, above the fold
  ═══════════════════════════════════════════════ -->
  <section class="bg-accent">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-5">
      <form
        id="inline-email-form"
        class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4"
      >
        <span class="font-[Archivo_Black] text-sm sm:text-base font-bold text-void tracking-tight whitespace-nowrap">
          Get the Weekly 2A Briefing
        </span>
        <input
          type="email"
          name="email"
          id="inline-email-input"
          placeholder="your@email.com"
          required
          class="w-full sm:w-72 bg-void/20 border border-void/30 px-4 py-2.5 font-[Crimson_Pro] text-void placeholder:text-void/50 focus:outline-none focus:border-void/60 focus:bg-void/30 transition-colors text-sm"
        />
        <button
          type="submit"
          id="inline-email-submit"
          class="font-[Archivo_Black] text-xs font-bold tracking-wider uppercase bg-void text-accent px-6 py-2.5 hover:bg-void/90 transition-colors whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <div id="inline-email-success" class="hidden text-center">
        <span class="font-[JetBrains_Mono] text-xs font-bold text-void tracking-wider">You're on the list.</span>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       ARTICLES GRID — Latest content
  ═══════════════════════════════════════════════ -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">

    <!-- Section header -->
    <div class="flex items-end justify-between mb-10 pb-6 border-b border-border">
      <div class="flex items-center gap-4">
        <div class="w-1 h-8 bg-accent"></div>
        <h2 class="font-[Archivo_Black] text-2xl sm:text-3xl font-bold text-text">Latest</h2>
      </div>
      <a
        href="/rss.xml"
        class="hidden sm:flex items-center gap-2 font-[JetBrains_Mono] text-[11px] tracking-widest uppercase text-text-muted hover:text-accent transition-colors"
        title="RSS Feed"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </div>

    <!-- Grid -->
    {remainingArticles.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {remainingArticles.map(article => (
          <ArticleCard
            title={article.data.title}
            date={article.data.date}
            slug={article.id}
            thumbnail={article.data.thumbnail}
            duration={article.data.duration}
            topics={article.data.topics}
            content_type={article.data.content_type}
          />
        ))}
      </div>
    ) : (
      <p class="font-[Crimson_Pro] text-text-muted text-center py-12">No additional articles yet.</p>
    )}

  </section>


  <!-- ═══════════════════════════════════════════════
       EMAIL CAPTURE — Full-width accent band
  ═══════════════════════════════════════════════ -->
  <section class="bg-accent">
    <div class="max-w-4xl mx-auto px-5 lg:px-8 py-16 sm:py-20">
      <div class="text-center">

        <!-- Label -->
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="w-8 h-px bg-void/30"></div>
          <span class="font-[JetBrains_Mono] text-[10px] tracking-[0.25em] uppercase text-void/70">
            Free Newsletter
          </span>
          <div class="w-8 h-px bg-void/30"></div>
        </div>

        <h2 class="font-[Archivo_Black] text-4xl sm:text-5xl font-bold text-void mb-5 tracking-tight">
          Weekly 2A Briefing
        </h2>
        <p class="font-[Crimson_Pro] text-void/80 text-xl leading-relaxed mb-10 max-w-lg mx-auto">
          Court rulings, legislative updates, and Second Amendment analysis — delivered free every week.
        </p>

        <form
          id="email-form"
          class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
        >
          <input
            type="email"
            name="email"
            id="email-input"
            placeholder="your@email.com"
            required
            class="flex-1 bg-void/20 border border-void/30 px-5 py-3.5 font-[Crimson_Pro] text-void placeholder:text-void/50 focus:outline-none focus:border-void/60 focus:bg-void/30 transition-colors text-lg"
          />
          <button
            type="submit"
            id="email-submit"
            class="font-[Archivo_Black] text-sm font-bold tracking-wider uppercase bg-void text-accent px-8 py-3.5 hover:bg-void/90 transition-colors whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>

        <p class="font-[JetBrains_Mono] text-[11px] text-void/50 mt-5 tracking-wide">
          No spam. Unsubscribe anytime.
        </p>

        <!-- Success state -->
        <div id="email-success" class="hidden mt-6">
          <div class="inline-flex items-center gap-2 bg-void/20 text-void px-5 py-3 font-[JetBrains_Mono] text-sm font-bold tracking-wider">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 13l4 4L19 7"/>
            </svg>
            You're on the list.
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       BROWSE BY TOPIC — Tag chips
  ═══════════════════════════════════════════════ -->
  {allTopics.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-20">
      <div class="border-t border-border pt-14">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
          <div class="w-1 h-8 bg-accent"></div>
          <h2 class="font-[Archivo_Black] text-2xl sm:text-3xl font-bold text-text">Browse by Topic</h2>
        </div>

        <!-- Chips -->
        <div class="flex flex-wrap gap-2.5">
          {allTopics.map(topic => (
            <a
              href={`/topics/${topic}`}
              class="group font-[JetBrains_Mono] text-[11px] tracking-widest uppercase text-text-secondary border border-border px-4 py-2.5 hover:border-accent hover:text-accent hover:bg-accent/5 transition-all duration-200"
            >
              {topic.replace(/-/g, ' ')}
            </a>
          ))}
        </div>

      </div>
    </section>
  )}


  <!-- Email form scripts -->
  <script is:inline>
    async function handleSubscribe(form, btnId, successId, inputId) {
      const btn = document.getElementById(btnId);
      const success = document.getElementById(successId);
      const email = document.getElementById(inputId)?.value;

      btn.textContent = 'Subscribing...';
      btn.disabled = true;

      try {
        const resp = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await resp.json();
        if (resp.ok) {
          form.style.display = 'none';
          success.classList.remove('hidden');
          // If subscribed via inline bar, also hide the main form
          document.querySelectorAll('[data-subscribe-form]').forEach(f => {
            f.style.display = 'none';
            f.closest('section')?.querySelector('[data-subscribe-success]')?.classList.remove('hidden');
          });
        } else {
          btn.textContent = data.error || 'Try Again';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    }

    // Main email form
    document.getElementById('email-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      handleSubscribe(this, 'email-submit', 'email-success', 'email-input');
    });

    // Inline email bar
    document.getElementById('inline-email-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      handleSubscribe(this, 'inline-email-submit', 'inline-email-success', 'inline-email-input');
    });
  </script>

</BaseLayout>
